---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Cobus van Vuuren — Business Automation Audits for SA Professional Services',
  description = 'Business Automation Audits for South African accountants, attorneys, and financial advisors. 90-minute intake, five-day turnaround, R50,000 minimum savings guaranteed or full refund.',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:locale" content="en_ZA" />

  <title>{title}</title>

  <!-- Fonts: Space Grotesk + Inter -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap"
    rel="stylesheet"
  />

  <!-- Additional head content (schema, page-specific meta) -->
  <slot name="head" />

  <!-- Google Tag Manager -->
  <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
  new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
  j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
  'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
  })(window,document,'script','dataLayer','GTM-KDZJDQR');</script>
</head>
<body class="antialiased">
  <!-- GTM noscript -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-KDZJDQR"
  height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>

  <!-- Background scene: grid + orbs + grain (grain is body::after in CSS) -->
  <div class="bg-scene" aria-hidden="true">
    <div class="bg-grid"></div>
    <div class="bg-orb bg-orb-crimson"></div>
    <div class="bg-orb bg-orb-warm"></div>
    <div class="bg-orb bg-orb-accent"></div>
  </div>

  <!-- NAV -->
  <nav class="fixed top-0 left-0 right-0 z-[9999] bg-[#0B0A09]/80 backdrop-blur-md border-b border-white/5">
    <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="/" class="font-serif font-normal text-[13px] tracking-[0.18em] uppercase text-ivory/90 hover:text-ivory transition-colors duration-300">
        Cobus van Vuuren
      </a>
      <div class="flex items-center gap-5">
        <a href="/articles" class="hidden md:block font-sans text-[12px] font-normal text-smoke hover:text-ivory/80 transition-colors duration-200">Articles</a>
        <a href="/about"    class="hidden md:block font-sans text-[12px] font-normal text-smoke hover:text-ivory/80 transition-colors duration-200">About</a>
        <a href="/score" class="btn-primary !py-2.5 !px-4 !text-[11px]">
          Free Diagnostic →
        </a>
      </div>
    </div>
  </nav>

  <!-- Page content -->
  <main class="relative z-[1]">
    <slot />
  </main>

  <!-- SITEWIDE INTERACTIONS -->
  <script is:inline>
  (function () {
    // Scroll reveal
    var obs = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) {
          e.target.classList.add('in-view');
          obs.unobserve(e.target);
        }
      });
    }, { threshold: 0.10, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('[data-anim]').forEach(function (el) { obs.observe(el); });

    // Magnetic buttons (desktop only)
    if (window.matchMedia('(pointer: fine)').matches) {
      document.querySelectorAll('.btn-primary, .btn-ghost-dark').forEach(function (btn) {
        btn.addEventListener('mousemove', function (e) {
          var r = btn.getBoundingClientRect();
          var x = ((e.clientX - r.left) / r.width - 0.5) * 9;
          var y = ((e.clientY - r.top) / r.height - 0.5) * 6;
          btn.style.transform = 'translate(' + x + 'px, ' + y + 'px)';
          btn.style.transition = 'transform 0.1s ease';
        });
        btn.addEventListener('mouseleave', function () {
          btn.style.transform = '';
          btn.style.transition = 'transform 0.45s ease, background-color 0.2s ease, box-shadow 0.2s ease';
        });
      });
    }

    // Number counters (elements with data-count attribute)
    var countObs = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (!entry.isIntersecting) return;
        var el = entry.target;
        var target = parseFloat(el.dataset.count);
        var isFloat = !!el.dataset.countFloat;
        var dur = 1100;
        var start = performance.now();
        function tick(now) {
          var t = Math.min((now - start) / dur, 1);
          var eased = 1 - Math.pow(1 - t, 3);
          el.textContent = isFloat ? (eased * target).toFixed(1) : Math.round(eased * target);
          if (t < 1) requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);
        countObs.unobserve(el);
      });
    }, { threshold: 0.5 });
    document.querySelectorAll('[data-count]').forEach(function (el) { countObs.observe(el); });
  })();
  </script>

  <!-- FOOTER -->
  <footer class="relative z-[1] border-t border-white/5 py-10">
    <div class="max-w-5xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="font-sans text-[13px] font-normal text-smoke">
        © 2026 Cobus van Vuuren. Business Automation Audits for SA professional services firms.
      </p>
      <div class="flex items-center gap-6">
        <a href="/privacy"  class="font-sans text-[12px] font-normal text-smoke hover:text-ivory transition-colors duration-200">Privacy</a>
        <a href="/terms"    class="font-sans text-[12px] font-normal text-smoke hover:text-ivory transition-colors duration-200">Terms</a>
        <a href="https://www.linkedin.com/in/cobusvanvuuren/" target="_blank" rel="noopener noreferrer" class="font-sans text-[12px] font-normal text-smoke hover:text-ivory transition-colors duration-200">LinkedIn</a>
        <a href="mailto:cobus@rhinoberry.com" class="font-sans text-[12px] font-normal text-smoke hover:text-ivory transition-colors duration-200">Email</a>
      </div>
    </div>
  </footer>

</body>
</html>
