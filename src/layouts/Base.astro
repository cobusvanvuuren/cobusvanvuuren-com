---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Cobus van Vuuren — Business Automation Audits for SA Professional Services',
  description = 'Business Automation Audits for South African accountants, attorneys, and financial advisors. 90-minute intake, five-day turnaround, R50,000 minimum savings guaranteed or full refund.',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:locale" content="en_ZA" />

  <title>{title}</title>

  <!-- Fonts: Cormorant + Inter -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Cormorant:ital,wght@0,200;0,300;0,400;1,200;1,300;1,400&family=Inter:wght@300;400;500;600&display=swap"
    rel="stylesheet"
  />

  <!-- Additional head content (schema, page-specific meta) -->
  <slot name="head" />
</head>
<body class="antialiased">

  <!-- Background scene: grid + orbs + grain (grain is body::after in CSS) -->
  <div class="bg-scene" aria-hidden="true">
    <div class="bg-grid"></div>
    <div class="bg-orb bg-orb-crimson"></div>
    <div class="bg-orb bg-orb-warm"></div>
    <div class="bg-orb bg-orb-accent"></div>
  </div>

  <!-- NAV -->
  <nav class="fixed top-0 left-0 right-0 z-[9999] bg-[#0B0A09]/80 backdrop-blur-md border-b border-white/5">
    <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="/" class="font-serif font-extralight text-[13px] tracking-[0.28em] uppercase text-ivory/90 hover:text-ivory transition-colors duration-300">
        Cobus van Vuuren
      </a>
      <div class="flex items-center gap-5">
        <a href="/articles" class="hidden md:block font-sans text-[12px] font-light text-smoke hover:text-ivory/80 transition-colors duration-200">Articles</a>
        <a href="/about"    class="hidden md:block font-sans text-[12px] font-light text-smoke hover:text-ivory/80 transition-colors duration-200">About</a>
        <a href="https://score.cobusvanvuuren.com" class="btn-primary !py-2.5 !px-4 !text-[11px]" target="_blank" rel="noopener">
          Free Scorecard →
        </a>
      </div>
    </div>
  </nav>

  <!-- Page content -->
  <main class="relative z-[1]">
    <slot />
  </main>

  <!-- FOOTER -->
  <footer class="relative z-[1] border-t border-white/5 py-10">
    <div class="max-w-5xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="font-sans text-[13px] font-light text-smoke">
        © 2026 Cobus van Vuuren. Business Automation Audits for SA professional services firms.
      </p>
      <div class="flex items-center gap-6">
        <a href="/privacy"  class="font-sans text-[12px] font-light text-smoke hover:text-ivory transition-colors duration-200">Privacy</a>
        <a href="/terms"    class="font-sans text-[12px] font-light text-smoke hover:text-ivory transition-colors duration-200">Terms</a>
        <a href="https://www.linkedin.com/in/cobus-van-vuuren" target="_blank" rel="noopener noreferrer" class="font-sans text-[12px] font-light text-smoke hover:text-ivory transition-colors duration-200">LinkedIn</a>
        <a href="mailto:cobus@cobusvanvuuren.com" class="font-sans text-[12px] font-light text-smoke hover:text-ivory transition-colors duration-200">Email</a>
      </div>
    </div>
  </footer>

</body>
</html>
