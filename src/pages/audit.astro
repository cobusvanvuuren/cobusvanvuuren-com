---
import Base from '../layouts/Base.astro';
---

<Base
  title="Business Automation Audit — Cobus van Vuuren"
  description="Stop guessing which AI system to build first. The Business Automation Audit maps every process in your SA professional services practice, ranks automation opportunities by ROI, and delivers a 90-day plan. R50,000 in savings identified — or full refund."
>

<style>
  /* ─── SHARED INNER WIDTH ───────────────────────────────────── */
  .inner {
    max-width: 980px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .inner-wide {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ─── HERO — full-bleed, centred ──────────────────────────── */
  .audit-hero {
    padding: 8rem 1.5rem 5rem;
    text-align: center;
    position: relative;
  }
  .hero-bloom {
    position: absolute;
    top: 0; left: 50%;
    transform: translateX(-50%);
    width: clamp(300px, 60vw, 700px);
    height: 340px;
    background: radial-gradient(ellipse at top, rgba(200,40,44,0.09) 0%, transparent 70%);
    pointer-events: none;
  }
  .a-eyebrow {
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-copper);
    margin-bottom: 1.75rem;
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }
  .a-eyebrow::before,
  .a-eyebrow::after {
    content: '';
    display: inline-block;
    width: 20px;
    height: 1px;
    background: var(--color-copper);
  }
  .a-h1 {
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 700;
    color: var(--color-ivory);
    line-height: 1.03;
    letter-spacing: -0.03em;
    margin: 0 auto 1.5rem;
    max-width: 900px;
  }
  .a-h1 em {
    font-style: italic;
    color: var(--color-crimson);
  }
  .a-sub {
    font-family: var(--font-sans);
    font-size: 1.05rem;
    color: var(--color-smoke);
    line-height: 1.8;
    max-width: 580px;
    margin: 0 auto 3rem;
  }

  /* Stats strip — 3 cols with dividers */
  .hero-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    max-width: 560px;
    margin: 0 auto 2.5rem;
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 14px;
    overflow: hidden;
  }
  .hero-stat {
    padding: 1.25rem 1.5rem;
    text-align: center;
    border-right: 1px solid rgba(255,255,255,0.07);
  }
  .hero-stat:last-child { border-right: none; }
  .hero-stat-num {
    font-family: var(--font-serif);
    font-size: 1.9rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1;
    margin-bottom: 0.35rem;
    color: var(--color-crimson);
  }
  .hero-stat:not(:first-child) .hero-stat-num { color: var(--color-ivory); }
  .hero-stat-label {
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-smoke);
    line-height: 1.35;
  }

  .hero-cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  /* ─── SECTION LABEL ───────────────────────────────────────── */
  .a-label {
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-copper);
    margin-bottom: 1.25rem;
  }

  /* ─── RULE ────────────────────────────────────────────────── */
  .a-rule {
    height: 1px;
    background: rgba(255,255,255,0.06);
    margin: 3.5rem 0;
  }

  /* ─── PROBLEM ─────────────────────────────────────────────── */
  .problem-block {
    padding: 3rem 0;
  }
  .problem-block p {
    font-family: var(--font-sans);
    font-size: 0.97rem;
    color: var(--color-smoke);
    line-height: 1.85;
    margin-bottom: 1rem;
    max-width: 640px;
  }
  .problem-block strong {
    color: var(--color-ivory);
    font-weight: 500;
  }

  /* ─── GUARANTEE — full-bleed ──────────────────────────────── */
  .guarantee-band {
    background: rgba(200,40,44,0.07);
    border-top: 1px solid rgba(200,40,44,0.3);
    border-bottom: 1px solid rgba(200,40,44,0.15);
    padding: 4rem 1.5rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .guarantee-band::before {
    content: '';
    position: absolute;
    top: -60px; left: 50%;
    transform: translateX(-50%);
    width: 400px;
    height: 300px;
    background: radial-gradient(circle, rgba(200,40,44,0.18) 0%, transparent 70%);
    pointer-events: none;
  }
  .g-icon {
    margin: 0 auto 1.25rem;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(200,40,44,0.4);
    border-radius: 12px;
    background: rgba(200,40,44,0.08);
    color: var(--color-crimson);
  }
  .g-label {
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-crimson);
    margin-bottom: 1rem;
  }
  .g-headline {
    font-family: var(--font-serif);
    font-size: clamp(1.6rem, 3.5vw, 2.6rem);
    font-weight: 700;
    color: var(--color-ivory);
    line-height: 1.2;
    letter-spacing: -0.025em;
    margin: 0 auto 1.25rem;
    max-width: 680px;
  }
  .g-body {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--color-smoke);
    line-height: 1.75;
    max-width: 500px;
    margin: 0 auto;
  }

  /* ─── DELIVERABLES GRID ───────────────────────────────────── */
  .deliverables-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 16px;
    overflow: hidden;
    margin-bottom: 3rem;
  }
  @media (min-width: 640px) {
    .deliverables-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 900px) {
    .deliverables-grid { grid-template-columns: repeat(3, 1fr); }
    .deliverables-grid .d-card:last-child { grid-column: span 1; }
  }
  .d-card {
    background: rgba(255,255,255,0.01);
    padding: 1.75rem;
    transition: background 0.2s ease;
  }
  .d-card:hover { background: rgba(255,255,255,0.03); }
  .d-num {
    font-family: var(--font-serif);
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--color-crimson);
    opacity: 0.7;
    margin-bottom: 0.75rem;
    display: block;
    letter-spacing: 0.05em;
  }
  .d-title {
    font-family: var(--font-serif);
    font-size: 0.97rem;
    font-weight: 600;
    color: var(--color-ivory);
    line-height: 1.3;
    margin-bottom: 0.5rem;
    display: block;
  }
  .d-desc {
    font-family: var(--font-sans);
    font-size: 0.83rem;
    color: var(--color-smoke);
    line-height: 1.65;
  }

  /* ─── ICP ─────────────────────────────────────────────────── */
  .icp-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-bottom: 1.25rem;
  }
  .icp-pill {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    color: var(--color-smoke);
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 100px;
    padding: 0.3rem 0.85rem;
    line-height: 1;
  }
  .icp-callout {
    border-left: 2px solid var(--color-copper);
    padding: 0.75rem 1rem;
    margin-top: 0.75rem;
    background: rgba(166,124,82,0.05);
    border-radius: 0 8px 8px 0;
  }
  .icp-callout p {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--color-smoke);
    line-height: 1.65;
    margin: 0;
  }
  .icp-callout strong {
    color: var(--color-ivory);
    font-weight: 500;
  }

  /* ─── PROCESS STEPS ───────────────────────────────────────── */
  .process-steps {
    display: grid;
    gap: 0;
    margin-bottom: 3rem;
  }
  .process-step {
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: 1.5rem;
    align-items: flex-start;
    padding-bottom: 2rem;
    position: relative;
  }
  .process-step:last-child { padding-bottom: 0; }
  .step-icon-wrap {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .step-icon {
    width: 56px;
    height: 56px;
    border: 1px solid rgba(200,40,44,0.35);
    border-radius: 14px;
    background: rgba(200,40,44,0.06);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-serif);
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-crimson);
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }
  .step-connector {
    width: 1px;
    flex: 1;
    min-height: 2rem;
    background: rgba(200,40,44,0.18);
    margin-top: 0.5rem;
  }
  .process-step:last-child .step-connector { display: none; }
  .step-time {
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-copper);
    margin-bottom: 0.3rem;
    display: block;
  }
  .step-content h3 {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-ivory);
    line-height: 1.3;
    margin-bottom: 0.5rem;
  }
  .step-content p {
    font-family: var(--font-sans);
    font-size: 0.87rem;
    color: var(--color-smoke);
    line-height: 1.7;
    margin: 0;
  }

  /* ─── FAQ ─────────────────────────────────────────────────── */
  .faq-list {
    display: grid;
    gap: 1px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 14px;
    overflow: hidden;
    margin-bottom: 3rem;
  }
  .faq-item {
    background: rgba(255,255,255,0.01);
  }
  .faq-item summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    font-family: var(--font-sans);
    font-size: 0.93rem;
    font-weight: 500;
    color: var(--color-ivory);
    cursor: pointer;
    user-select: none;
    transition: background 0.15s ease;
  }
  .faq-item summary:hover { background: rgba(255,255,255,0.03); }
  .faq-item[open] summary { border-bottom: 1px solid rgba(255,255,255,0.05); }
  .faq-body {
    padding: 1.1rem 1.5rem 1.25rem;
    font-family: var(--font-sans);
    font-size: 0.87rem;
    color: var(--color-smoke);
    line-height: 1.75;
  }
  .faq-body strong { color: var(--color-ivory); font-weight: 500; }

  /* ─── PRICING ─────────────────────────────────────────────── */
  .pricing-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 1px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 16px;
    overflow: hidden;
    margin-bottom: 2.5rem;
  }
  @media (max-width: 500px) { .pricing-grid { grid-template-columns: 1fr; } }
  .price-cell {
    background: #0B0A09;
    padding: 2rem;
  }
  .price-cell.featured {
    background: rgba(200,40,44,0.05);
    padding-top: 3rem; /* room for .pricing-featured banner */
  }
  .price-tag {
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-copper);
    margin-bottom: 0.75rem;
  }
  .price-amount {
    font-family: var(--font-serif);
    font-size: 3.4rem;
    font-weight: 700;
    color: var(--color-ivory);
    letter-spacing: -0.04em;
    line-height: 1;
    margin-bottom: 0.6rem;
  }
  .price-cell:not(.featured) .price-amount {
    font-size: 2.8rem;
    color: rgba(247,244,239,0.3);
    text-decoration: line-through;
    text-decoration-color: rgba(247,244,239,0.18);
  }
  .price-desc {
    font-family: var(--font-sans);
    font-size: 0.82rem;
    color: var(--color-smoke);
    line-height: 1.65;
    margin-bottom: 1.25rem;
  }
  .price-checklist {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.45rem;
  }
  .price-checklist li {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    color: var(--color-smoke);
    line-height: 1.4;
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
  }
  .price-checklist li::before {
    content: '✓';
    color: var(--color-crimson);
    font-weight: 700;
    font-size: 0.78rem;
    flex-shrink: 0;
    margin-top: 0.05rem;
  }
  .price-spots {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: rgba(200,40,44,0.8);
    font-weight: 500;
    letter-spacing: 0.04em;
    margin-top: 1rem;
  }

  /* ─── CTA BAND — full-bleed ───────────────────────────────── */
  .cta-band {
    padding: 5rem 1.5rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .cta-band::before {
    content: '';
    position: absolute;
    bottom: 0; left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 300px;
    background: radial-gradient(ellipse at bottom, rgba(200,40,44,0.10) 0%, transparent 70%);
    pointer-events: none;
  }
  .cta-band h2 {
    font-family: var(--font-serif);
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 700;
    color: var(--color-ivory);
    letter-spacing: -0.025em;
    line-height: 1.15;
    margin-bottom: 2rem;
    max-width: 620px;
    margin-left: auto;
    margin-right: auto;
  }
  .cta-stack {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }
  .a-link {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--color-smoke);
    line-height: 1.65;
    margin-top: 0.5rem;
  }
  .a-link a {
    color: var(--color-ivory);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* ─── STICKY MOBILE CTA ───────────────────────────────────── */
  .sticky-cta-bar {
    display: none;
    position: fixed;
    bottom: 0; left: 0; right: 0;
    z-index: 100;
    background: rgba(11,10,9,0.96);
    border-top: 1px solid rgba(255,255,255,0.08);
    padding: 0.85rem 1.25rem calc(0.85rem + env(safe-area-inset-bottom));
    backdrop-filter: blur(8px);
  }
  @media (max-width: 768px) {
    .sticky-cta-bar { display: block; }
    body { padding-bottom: 72px; }
  }
</style>

<!-- HERO — full-bleed, centred -->
<section class="audit-hero">
  <div class="hero-bloom"></div>
  <div class="inner-wide" style="position:relative;z-index:1;">
    <p class="a-eyebrow">Business Automation Audit</p>
    <h1 class="a-h1">You know you need better systems.<br/>This audit tells you <em>exactly what to build</em> — for your business.</h1>
    <p class="a-sub">Generic AI advice is everywhere. What's specific to your business type, your workflow gaps, and your team size is rare. The Business Automation Audit maps every process, ranks every opportunity by ROI, and delivers a 90-day plan built for you — not a generic firm.</p>

    <div class="hero-stats">
      <div class="hero-stat">
        <p class="hero-stat-num">R50k</p>
        <p class="hero-stat-label">Minimum savings<br/>guaranteed</p>
      </div>
      <div class="hero-stat">
        <p class="hero-stat-num">90 min</p>
        <p class="hero-stat-label">Intake session</p>
      </div>
      <div class="hero-stat">
        <p class="hero-stat-num">5 days</p>
        <p class="hero-stat-label">To your report</p>
      </div>
    </div>

    <div class="hero-cta">
      <a href="https://pay.cobusvanvuuren.com/audit" class="btn-primary" target="_blank" rel="noopener">
        Claim Your Audit — R5,497 →
      </a>
      <a href="https://call.rhinoberry.com/meeting" class="btn-ghost-dark" target="_blank" rel="noopener">
        Book a free 20-min call first
      </a>
    </div>
  </div>
</section>

<!-- PROBLEM — PAS agitation -->
<div class="inner">
  <div class="problem-block">
    <p>You've probably looked at AI tools. Maybe tried a few. And you walked away with the same feeling: <strong>where do I actually start with my specific business?</strong></p>
    <p>The problem isn't a lack of options. It's that nobody has mapped YOUR workflows, ranked YOUR bottlenecks, and told you exactly what to build in what order. So you keep experimenting. And the time and money keeps leaking.</p>
    <p>That's what this audit fixes.</p>
  </div>
</div>

<!-- GUARANTEE — full-bleed, maximum weight -->
<div class="guarantee-band">
  <div class="inner-wide" style="position:relative;z-index:1;">
    <div class="g-icon">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        <polyline points="9 12 11 14 15 10"/>
      </svg>
    </div>
    <p class="g-label">The Guarantee</p>
    <h2 class="g-headline">Find R50,000 in annual savings — or pay nothing.</h2>
    <p class="g-body">If the audit doesn't identify at least R50,000 in annual savings opportunities specific to your business, you receive a full refund within 5 business days. No questions asked. The risk is ours — not yours.</p>
  </div>
</div>

<!-- WHAT YOU GET -->
<div class="inner" style="padding-top:3.5rem;">
  <p class="a-label">What you get</p>
  <div class="deliverables-grid">
    <div class="d-card">
      <span class="d-num">01</span>
      <span class="d-title">A complete process map</span>
      <p class="d-desc">Every workflow where you're losing principal time to non-expert work — documented and ranked by cost.</p>
    </div>
    <div class="d-card">
      <span class="d-num">02</span>
      <span class="d-title">Ranked automation opportunities</span>
      <p class="d-desc">Every gap ordered by ROI — highest-return fixes first. No guessing. No generic frameworks.</p>
    </div>
    <div class="d-card">
      <span class="d-num">03</span>
      <span class="d-title">Specific tool and workflow recommendations</span>
      <p class="d-desc">Built for your business type, your team size, and the tools you already use. Not theory — actual systems.</p>
    </div>
    <div class="d-card">
      <span class="d-num">04</span>
      <span class="d-title">A prioritised 90-day implementation plan</span>
      <p class="d-desc">What to build first, second, and third — with the reason behind the sequence.</p>
    </div>
    <div class="d-card">
      <span class="d-num">05</span>
      <span class="d-title">30-minute delivery call</span>
      <p class="d-desc">Walk through the report together. Ask questions. Leave with a clear next step.</p>
    </div>
  </div>

  <div class="a-rule"></div>

  <!-- WHO IT'S FOR -->
  <p class="a-label">Built for SA professional services</p>
  <div class="icp-grid">
    <span class="icp-pill">Accountants</span>
    <span class="icp-pill">CA(SA)s</span>
    <span class="icp-pill">Tax practitioners</span>
    <span class="icp-pill">Attorneys</span>
    <span class="icp-pill">Financial advisors</span>
    <span class="icp-pill">GPs &amp; specialists</span>
    <span class="icp-pill">Consulting engineers</span>
    <span class="icp-pill">Management consultants</span>
    <span class="icp-pill">Architects</span>
    <span class="icp-pill">Property agents</span>
  </div>
  <div class="icp-callout">
    <p><strong>Any business where the principal's expertise is the product and the principal is the bottleneck.</strong> If your clients are paying for your judgment, and you can't scale without hiring a clone of yourself — this is built for you.</p>
  </div>

  <div class="a-rule"></div>

  <!-- THE PROCESS -->
  <p class="a-label">How it works</p>
  <div class="process-steps">
    <div class="process-step">
      <div class="step-icon-wrap">
        <div class="step-icon">01</div>
        <div class="step-connector"></div>
      </div>
      <div class="step-content">
        <span class="step-time">90 minutes</span>
        <h3>Intake</h3>
        <p>A structured conversation covering your workflows, team, tools, and recurring bottlenecks. Done by voice call or written form. Most principals find this session valuable on its own — mapping it out loud surfaces things that have been invisible for years.</p>
      </div>
    </div>
    <div class="process-step">
      <div class="step-icon-wrap">
        <div class="step-icon">02</div>
        <div class="step-connector"></div>
      </div>
      <div class="step-content">
        <span class="step-time">5 business days</span>
        <h3>Analysis</h3>
        <p>Every process audited against the AI readiness framework. Automation opportunities ranked by ROI. Tool and workflow recommendations scoped to your business type, team size, and existing stack.</p>
      </div>
    </div>
    <div class="process-step">
      <div class="step-icon-wrap">
        <div class="step-icon">03</div>
