---
import Base from '../layouts/Base.astro';

const articles = [
  {
    tag: 'Owner Bottleneck',
    title: 'Why SA professional services firms lose 15–25% of billable hours annually',
    date: 'May 2026',
    readTime: '8 min read',
    excerpt: 'Most firms have no idea where the time goes. The data does — and the number is always the same.',
    slug: 'billable-hours-professional-services',
  },
  {
    tag: 'Time Leaks',
    title: 'The 5 most common time leaks in an accounting, law, or FSP practice',
    date: 'May 2026',
    readTime: '6 min read',
    excerpt: 'Five patterns that show up in almost every practice audit. The first one will surprise you.',
    slug: 'time-leaks-professional-practice',
  },
  {
    tag: 'Automation',
    title: 'What is a Business Automation Audit — and why would you pay R15,000 for one?',
    date: 'May 2026',
    readTime: '7 min read',
    excerpt: 'A structured answer to the most common question I get. With the maths.',
    slug: 'what-is-business-automation-audit',
  },
];

const videos = [
  {
    title: 'Owner as Bottleneck: how to stop being the reason your practice can\'t grow',
    duration: '12 min',
    tag: 'Owner Bottleneck',
  },
  {
    title: 'The first AI workflow every SA professional should set up — and why most start wrong',
    duration: '8 min',
    tag: 'Automation',
  },
  {
    title: 'Why your competitors convert leads 21× faster than you — and what to do about it',
    duration: '6 min',
    tag: 'Sales AI',
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": "https://cobusvanvuuren.com/#person",
      "name": "Cobus van Vuuren",
      "url": "https://cobusvanvuuren.com",
      "jobTitle": "Business Automation Consultant",
      "description": "Maps time leaks inside SA professional services firms and shows where AI changes the maths.",
      "worksFor": { "@type": "Organization", "name": "RhinoBerry" },
      "sameAs": ["https://www.linkedin.com/in/cobusvanvuuren/"]
    }
  ]
};
---

<Base
  title="Cobus van Vuuren — AI and Automation for SA Professional Services"
  description="I map the time leaks inside SA professional services firms and show exactly where automation changes the maths. Articles, videos, and the Business Automation Audit."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    <style>
      /* Hero radial glow behind heading */
      .hero-bloom {
        position: absolute;
        top: 5%;
        left: -5%;
        width: 65%;
        height: 90%;
        background: radial-gradient(ellipse at 30% 40%,
          rgba(200, 40, 44, 0.10) 0%,
          rgba(200, 40, 44, 0.04) 35%,
          transparent 70%
        );
        pointer-events: none;
      }

/* Proof strip — 4 stats below the hero CTAs */
      .proof-strip {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1.5rem;
        border-top: 1px solid rgba(255,255,255,0.06);
        padding-top: 2rem;
      }
      @media (max-width: 640px) {
        .proof-strip { grid-template-columns: repeat(2, 1fr); }
      }
      .proof-strip-num {
        font-family: var(--font-serif);
        font-size: 1.6rem;
        font-weight: 700;
        color: var(--color-crimson);
        letter-spacing: -0.03em;
        line-height: 1;
        display: block;
        margin-bottom: 0.35rem;
      }
      .proof-strip-label {
        font-family: var(--font-sans);
        font-size: 0.72rem;
        color: var(--color-smoke);
        line-height: 1.5;
        margin: 0;
      }

      /* Content card */
      .content-card {
        display: block;
        border: 1px solid rgba(255, 255, 255, 0.07);
        border-radius: 12px;
        padding: 2rem;
        text-decoration: none;
        transition: border-color 0.25s ease, background-color 0.25s ease, transform 0.2s ease;
        background: rgba(255, 255, 255, 0.02);
      }
      .content-card:hover {
        border-color: rgba(255, 255, 255, 0.14);
        background: rgba(255, 255, 255, 0.04);
        transform: translateY(-2px);
      }

      /* Video thumbnail placeholder */
      .video-thumb {
        aspect-ratio: 16 / 9;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1rem;
        position: relative;
        overflow: hidden;
      }
      .video-thumb::before {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse at center, rgba(200,40,44,0.06) 0%, transparent 70%);
      }
      .play-icon {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.12);
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        z-index: 1;
      }
      .play-icon::after {
        content: '';
        border-style: solid;
        border-width: 7px 0 7px 14px;
        border-color: transparent transparent transparent rgba(255,255,255,0.7);
        margin-left: 3px;
      }

      /* Tag */
      .tag {
        display: inline-block;
        font-family: var(--font-sans);
        font-size: 10px;
        font-weight: 500;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--color-smoke);
        margin-bottom: 0.75rem;
      }

      /* Two-path CTA cards */
      .path-card {
        border-radius: 16px;
        padding: 3rem;
        border: 1px solid rgba(255, 255, 255, 0.08);
        background: rgba(255, 255, 255, 0.02);
        transition: border-color 0.25s ease;
      }
      .path-card-primary {
        border-color: rgba(200, 40, 44, 0.3);
        background: rgba(200, 40, 44, 0.04);
      }
      .path-card:hover { border-color: rgba(255, 255, 255, 0.14); }
      .path-card-primary:hover { border-color: rgba(200, 40, 44, 0.5); }

      /* Section rule — crimson */
      .section-rule {
        width: 100%;
        height: 1px;
        background: rgba(200, 40, 44, 0.28);
        margin: 0 0 4rem 0;
      }

      /* Proof numbers */
      .proof-num {
        font-family: var(--font-serif);
        font-weight: 700;
        line-height: 0.88;
        background: linear-gradient(135deg, #ffffff 0%, rgba(255,255,255,0.4) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }


      /* About portrait placeholder */
      .portrait-frame {
        width: 100%;
        max-width: 300px;
        aspect-ratio: 3/4;
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 12px;
        background: rgba(255,255,255,0.02);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        position: relative;
        overflow: hidden;
      }
      .portrait-frame::before {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse at 50% 30%, rgba(200,40,44,0.04) 0%, transparent 70%);
        pointer-events: none;
      }
      .portrait-initials {
        font-family: var(--font-serif);
        font-size: 5rem;
        font-weight: 700;
        color: rgba(255,255,255,0.06);
        letter-spacing: -0.05em;
        line-height: 1;
        position: relative;
        z-index: 1;
      }
      .portrait-placeholder-text {
        font-family: var(--font-sans);
        font-size: 0.62rem;
        color: rgba(122,118,110,0.35);
        letter-spacing: 0.12em;
        text-transform: uppercase;
        position: relative;
        z-index: 1;
      }
    </style>
  </Fragment>


  <!-- ══════════════════════════════════════════ -->
  <!-- HERO                                      -->
  <!-- ══════════════════════════════════════════ -->
  <section class="relative min-h-screen overflow-hidden">
    <div class="hero-bloom"></div>

    <!-- Full-width centered text — no portrait in hero -->
    <div class="relative flex items-center min-h-screen">
      <div class="w-full max-w-4xl mx-auto flex flex-col justify-center pt-28 pb-20 px-8 sm:px-12 lg:px-16">

        <div class="eyebrow mb-8">
          <span class="eyebrow-label">Business Automation · South Africa</span>
        </div>

        <h1 class="font-serif font-bold text-ivory text-[clamp(2.2rem,4vw,3.6rem)] leading-[1.06] tracking-[-0.03em] mb-6 max-w-3xl">
          Most SA business owners know they need AI.
          Almost none know where to start.
        </h1>

        <p class="font-sans font-normal text-[16px] text-[#B0ABA4] leading-[1.8] max-w-xl mb-10">
          I help SA business owners find where they're losing time and revenue —
          and build the systems to stop it. No generic AI advice. Specific findings, specific fixes.
        </p>

        <div class="flex flex-col sm:flex-row gap-3 mb-12">
          <a href="/score" class="btn-primary text-center">
            Take the Free AI Readiness Diagnostic →
          </a>
          <a href="https://call.rhinoberry.com/meeting" class="btn-ghost-dark text-center" target="_blank" rel="noopener" onclick="gtag('event', 'strategy_call_intent', {event_category: 'CTA', event_label: 'hero'})">
            Book a Strategy Call
          </a>
        </div>

        <!-- Context strip -->
        <div class="flex flex-wrap gap-x-5 gap-y-2 text-[12px] font-sans font-normal text-smoke border-t border-white/7 pt-7 mb-12">
          <span>Accountants · Attorneys · Financial Advisors</span>
          <span class="text-white/15 hidden sm:block">|</span>
          <span>3–20 staff · South Africa</span>
          <span class="text-white/15 hidden sm:block">|</span>
          <span>R50,000 minimum savings guaranteed</span>
        </div>

        <!-- Proof strip: 3 numbers -->
        <div class="proof-strip">
          <div>
            <span class="proof-strip-num">24<span style="font-size:0.62em;font-weight:500"> days</span></span>
            <p class="proof-strip-label">lost to admin per year — avg SA business owner</p>
          </div>
          <div>
            <span class="proof-strip-num">37<span style="font-size:0.62em;font-weight:500">%</span></span>
            <p class="proof-strip-label">avg attorney billable utilisation — 63% disappears</p>
          </div>
          <div>
            <span class="proof-strip-num">21<span style="font-size:0.62em;font-weight:500">×</span></span>
            <p class="proof-strip-label">more likely to convert — 5 min vs 42 hrs response</p>
          </div>
        </div>

      </div>
    </div>
  </section>


  <!-- ══════════════════════════════════════════ -->
  <!-- LATEST ARTICLES                           -->
  <!-- ══════════════════════════════════════════ -->
  <section class="max-w-6xl mx-auto px-6 pt-20 pb-24">
    <div class="section-rule"></div>

    <div class="flex items-baseline justify-between mb-14">
      <h2 class="font-sans font-semibold text-ivory text-2xl">Latest articles</h2>
      <a href="/articles" class="font-sans font-normal text-[13px] text-smoke hover:text-ivory transition-colors duration-200">
        All articles →
      </a>
    </div>

    <div class="grid md:grid-cols-3 gap-4">
      {articles.map(article => (
        <a href={`/articles/${article.slug}`} class="content-card flex flex-col">
          <span class="tag">{article.tag}</span>
          <h3 class="font-sans font-semibold text-ivory/90 text-[15px] leading-[1.45] mb-3 flex-1">
            {article.title}
          </h3>
          <p class="font-sans font-normal text-[#B0ABA4] text-[13px] leading-[1.65] mb-4">
            {article.excerpt}
          </p>
          <p class="font-sans font-normal text-[11px] text-smoke/50 mt-auto">
            {article.date} · {article.readTime}
          </p>
        </a>
      ))}
    </div>
  </section>




  <!-- ══════════════════════════════════════════ -->
  <!-- STATS STRIP                               -->
  <!-- ══════════════════════════════════════════ -->
  <section class="max-w-6xl mx-auto px-6 pt-20 pb-24">
    <div class="section-rule"></div>

    <div class="grid md:grid-cols-3 gap-8">
      {[
        { num: '24', unit: ' days', label: 'Lost per year to admin — average SA business owner, at billing rate' },
        { num: '37', unit: '%', label: 'Average attorney billable utilisation. 63% disappears to work that shouldn\'t need them.' },
        { num: '21', unit: '×', label: 'More likely to convert a lead contacted within 5 minutes vs the SA average of 42 hours.' },
      ].map(stat => (
        <div class="border-t border-white/8 pt-6">
          <p class="font-serif font-bold text-ivory text-[3rem] leading-none mb-3">
            {stat.num}<span class="text-[0.55em]">{stat.unit}</span>
          </p>
          <p class="font-sans font-normal text-[#B0ABA4] text-sm leading-[1.65]">{stat.label}</p>
        </div>
      ))}
    </div>
  </section>


  <!-- ══════════════════════════════════════════ -->
  <!-- ABOUT                                     -->
  <!-- ══════════════════════════════════════════ -->
  <section class="max-w-6xl mx-auto px-6 pt-20 pb-24">
    <div class="section-rule"></div>

    <div class="grid md:grid-cols-2 gap-12 lg:gap-16 items-start">
      <!-- Text column -->
      <div>
        <div class="eyebrow"><span class="eyebrow-label">About</span></div>
        <p class="font-serif font-bold text-ivory text-[clamp(1.5rem,2.5vw,2rem)] leading-[1.2] tracking-[-0.02em] mb-6">
          I built a business, automated it, then started helping other SA
          professional services firms do the same.
        </p>
        <p class="font-sans font-normal text-[#B0ABA4] text-base leading-[1.80] mb-6">
          Seven years running RhinoBerry — a digital marketing agency — meant running every manual
          process first, then spending three years automating the parts that were eating my evenings.
          Client intake, proposal generation, reporting, billing, content production. The audit methodology
          is what I use on my own business. Not what I theorise about.
        </p>
        <p class="font-sans font-normal text-[#B0ABA4] text-base leading-[1.80] mb-8">
          CVV is where I share what I'm learning about building better business systems —
          growth, automation, and the patterns that actually work for SA owner-operators.
          RhinoBerry is where the marketing implementation lives. The two are connected.
        </p>
        <a href="/about" class="font-sans font-normal text-[13px] text-smoke hover:text-ivory transition-colors duration-200">
          More about me →
        </a>
      </div>
      <!-- Portrait — small, bottom of page -->
      <div class="flex justify-center md:justify-start">
        <div class="portrait-frame">
          <img
            src="/images/cobus-hero.webp"
            alt="Cobus van Vuuren"
            style="width: 100%; height: 100%; object-fit: cover; object-position: top center; border-radius: 10px;"
          />
        </div>
      </div>
    </div>
  </section>


  <!-- ══════════════════════════════════════════ -->
  <!-- TWO PATHS CTA                             -->
  <!-- ══════════════════════════════════════════ -->
  <section class="max-w-6xl mx-auto px-6 pt-20 pb-40">
    <div class="section-rule"></div>

    <div class="eyebrow"><span class="eyebrow-label">Where to start</span></div>

    <div class="grid md:grid-cols-2 gap-8">

      <!-- Path 1: Free Scorecard -->
      <div class="path-card path-card-primary">
        <p class="font-sans font-medium text-crimson text-[11px] tracking-[0.14em] uppercase mb-4">Free — 5 minutes</p>
        <h3 class="font-serif font-bold text-ivory text-[1.75rem] leading-[1.2] mb-4">
          AI Readiness Scorecard
        </h3>
        <p class="font-sans font-normal text-[#B0ABA4] text-sm leading-[1.70] mb-8">
          20 questions. Score from 0–200. Find out exactly where your business stands —
          time leaks, automation gaps, speed-to-lead. Personalised results on screen immediately.
          No pitch. Genuinely useful whether you book an audit or not.
        </p>
        <a href="/score" class="btn-primary block text-center w-full">
          Take the Diagnostic →
        </a>
      </div>

      <!-- Path 2: Strategy Call -->
      <div class="path-card">
        <p class="font-sans font-medium text-smoke text-[11px] tracking-[0.14em] uppercase mb-4">R2,500 · 90 minutes</p>
        <h3 class="font-serif font-bold text-ivory text-[1.75rem] leading-[1.2] mb-4">
          Strategy Call
        </h3>
        <p class="font-sans font-normal text-[#B0ABA4] text-sm leading-[1.70] mb-6">
          Skip the scorecard. Book directly. We map your specific workflows live on a Zoom call,
          identify the highest-leverage automation opportunities, and you leave with a written
          summary of exactly where to start. R2,500 credited against the full audit if you proceed.
        </p>
        <a href="https://call.rhinoberry.com/meeting" class="btn-ghost-dark block text-center w-full" target="_blank" rel="noopener" onclick="gtag('event', 'strategy_call_intent', {event_category: 'CTA', event_label: 'path-card'})">
          Book a Strategy Call →
        </a>
        <p class="font-sans font-normal text-[11px] text-smoke/40 text-center mt-4">
          Looking for the full Business Automation Audit? <a href="/audit" class="text-smoke/70 hover:text-smoke underline underline-offset-2">See the audit →</a>
        </p>
      </div>

    </div>
  </section>

</Base>
