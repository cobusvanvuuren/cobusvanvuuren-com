    intro: {
      headline: '"You can\'t leverage what you\'re still doing yourself."',
      body: 'Research shows professional services firms lose 15–25% of billable hours annually to tasks that don\'t require the principal\'s expertise — admin, reporting, compliance paperwork, client follow-ups. Time Reclamation is about identifying those leaks and systematically closing them.',
    },
    questions: [
      { text: 'I\'ve identified and quantified how many hours per week I spend on tasks that don\'t require my professional expertise.', type: 'yesno' },
      { text: 'I regularly review whether tasks on my plate could be handled by a documented system or a team member.', type: 'freq' },
      { text: 'I\'ve moved at least one major recurring task off my plate in the past 3 months — delegated or automated.', type: 'yesno' },
      { text: 'My practice can function for at least 3 days without my direct input.', type: 'yesno' },
      { text: 'I have a clear picture of what my practice looks like when it runs without me — and I\'m actively building toward it.', type: 'slider' },
    ],
  },
];

const PROFILES = [
  {
    question: 'What best describes your practice?',
    options: [
      { text: 'Professional services (accounting, legal, advisory, financial planning)', tag: 'prof-services' },
      { text: 'Healthcare or wellness (medical, dental, physio, specialist)', tag: 'healthcare' },
      { text: 'Real estate or property (sales, lettings, management)', tag: 'property' },
      { text: 'Trade or construction (electrical, plumbing, HVAC, building)', tag: 'trade' },
      { text: 'Other', tag: 'other' },
    ],
  },
  {
    question: 'How many people work in your practice, including you?',
    options: [
      { text: 'Just me', tag: 'solo' },
      { text: '2–4', tag: 'micro' },
      { text: '5–15', tag: 'sweet-spot' },
      { text: '16–50', tag: 'mid' },
      { text: '51+', tag: 'large' },
    ],
  },
  {
    question: 'What\'s the single biggest thing stopping your practice from running the way you envisioned when you started?',
    options: [
      { text: 'Too much work runs through me personally — I\'m the bottleneck', tag: 'owner-bottleneck' },
      { text: 'Systems aren\'t in place — things fall through the cracks', tag: 'no-systems' },
      { text: 'Too busy to properly handle the leads I already have', tag: 'lead-overflow' },
      { text: 'All of the above', tag: 'all-of-above' },
    ],
  },
];

const LETTERS = ['A', 'B', 'C', 'D', 'E'];
const YESNO_OPTIONS = [
  { text: 'Not yet', value: 0 },
  { text: 'Getting there', value: 5 },
  { text: 'Yes — nailed it', value: 10 },
];
const FREQ_OPTIONS = [
  { text: 'Never', value: 0 },
  { text: 'Rarely', value: 2 },
  { text: 'Sometimes', value: 5 },
  { text: 'Often', value: 8 },
  { text: 'Always', value: 10 },
];

// ── STATE ────────────────────────────────────────────────────
const STORAGE_KEY = 'cvv_diagnostic_state';
const SESSION_TTL = 60 * 60 * 1000; // 60 minutes

// Clear state if navigating in from outside /score (e.g. nav button, homepage CTA)
// Keep state on reload or back-button so mid-quiz progress is preserved
(function clearOnExternalNav() {
  try {
    const navType = performance.getEntriesByType('navigation')[0]?.type;
    const isReload = navType === 'reload' || navType === 'back_forward';
    if (!isReload) {
      const ref = document.referrer;
      const fromScore = ref && new URL(ref).pathname.startsWith('/score');
      if (!fromScore) sessionStorage.removeItem(STORAGE_KEY);
    }
  } catch {}
})();

function loadState() {
  try {
    const raw = sessionStorage.getItem(STORAGE_KEY);
    if (!raw) return null;
    const s = JSON.parse(raw);
    if (Date.now() - new Date(s.startedAt).getTime() > SESSION_TTL) {
      sessionStorage.removeItem(STORAGE_KEY);
      return null;
    }
    return s;
  } catch { return null; }
}

function saveState(s) {
  try { sessionStorage.setItem(STORAGE_KEY, JSON.stringify(s)); } catch {}
}

function freshState() {
  return {
    phase: 'landing', // landing | profile | scored | gate | calculating
    profileStep: 0,   // 0–2
    scoredStep: 0,    // 0–19 (maps to sys 0–3 q 0–4)
    profile: {},      // { type, size, pain }
    answers: {},      // { q0: 5, q1: 7, ... }
    name: '',
    email: '',
    startedAt: new Date().toISOString(),
  };
}

let state = loadState() || freshState();
let expiredShown = false;

// ── DOM REFS ─────────────────────────────────────────────────
const landing      = document.getElementById('landing');
const quiz         = document.getElementById('quiz');
const emailGate    = document.getElementById('email-gate');
const calculating  = document.getElementById('calculating');

const systemLabel  = document.getElementById('system-label');
const stepCount    = document.getElementById('step-count');
const progressFill = document.getElementById('progress-fill');
const systemIntro  = document.getElementById('system-intro');
const introHeadline= document.getElementById('intro-headline');
const introBody    = document.getElementById('intro-body');

const profileScreen  = document.getElementById('profile-screen');
const profileQuestion= document.getElementById('profile-question');
const profileChoices = document.getElementById('profile-choices');
const btnProfileBack = document.getElementById('btn-profile-back');
const btnProfileNext = document.getElementById('btn-profile-next');

const scoredScreen   = document.getElementById('scored-screen');
const scoredQuestion = document.getElementById('scored-question');
const sliderNum      = document.getElementById('slider-num');
const diagSlider     = document.getElementById('diag-slider');
const btnScoredBack     = document.getElementById('btn-scored-back');
const btnScoredNext     = document.getElementById('btn-scored-next');
const scoredSliderWrap  = document.getElementById('scored-slider-wrap');
const scoredChoices     = document.getElementById('scored-choices');

const gateName    = document.getElementById('gate-name');
const gateEmail   = document.getElementById('gate-email');
const gateConsent = document.getElementById('gate-consent');
const btnGateBack = document.getElementById('btn-gate-back');
const btnGateNext = document.getElementById('btn-gate-next');

// ── HELPERS ──────────────────────────────────────────────────
function hide(...els) { els.forEach(e => { if (e) e.style.display = 'none'; }); }
function show(el, display = 'block') { if (el) el.style.display = display; }

function sysIdx(scoredStep) { return Math.floor(scoredStep / 5); }
function qIdx(scoredStep)   { return scoredStep % 5; }

function updateProgress(scoredStep) {
  const pct = (scoredStep / 20) * 100;
  progressFill.style.width = pct + '%';
  stepCount.textContent = `Q ${scoredStep + 1} of 20`;
  systemLabel.textContent = SYSTEMS[sysIdx(scoredStep)].label;
}

function renderProfileScreen(step) {
  const p = PROFILES[step];
  profileQuestion.textContent = p.question;
  profileChoices.innerHTML = '';
  btnProfileNext.disabled = true;

  p.options.forEach((opt, idx) => {
    const btn = document.createElement('button');
    btn.className = 'choice-card';
    btn.innerHTML = `<span class="choice-label">${LETTERS[idx]}</span><span class="choice-radio"></span><span>${opt.text}</span>`;
    btn.dataset.tag = opt.tag;

    const savedTag = Object.values(state.profile)[step];
    if (savedTag === opt.tag) btn.classList.add('selected');

    btn.addEventListener('click', () => {
      profileChoices.querySelectorAll('.choice-card').forEach(c => c.classList.remove('selected'));
      btn.classList.add('selected');
      const keys = ['type', 'size', 'pain'];
      state.profile[keys[step]] = opt.tag;
      saveState(state);
      btnProfileNext.disabled = false;
      setTimeout(() => btnProfileNext.click(), 280);
    });

    profileChoices.appendChild(btn);
  });

  btnProfileBack.disabled = step === 0;
  show(profileScreen);
  hide(scoredScreen, systemIntro);
}

function renderScoredChoices(step, type) {
  const opts = type === 'yesno' ? YESNO_OPTIONS : FREQ_OPTIONS;
  const savedVal = state.answers[`q${step}`];

  scoredChoices.className = type;
  scoredChoices.style.display = type === 'yesno' ? 'grid' : 'flex';
  scoredChoices.innerHTML = '';
  btnScoredNext.disabled = (savedVal === undefined);

  opts.forEach((opt, idx) => {
    const btn = document.createElement('button');
    btn.className = 'choice-card';
    if (type === 'yesno') {
      btn.innerHTML = `<span>${opt.text}</span>`;
    } else {
      btn.innerHTML = `<span class="choice-label">${LETTERS[idx]}</span><span class="choice-radio"></span><span>${opt.text}</span>`;
    }
    if (savedVal === opt.value) btn.classList.add('selected');

    btn.addEventListener('click', () => {
      scoredChoices.querySelectorAll('.choice-card').forEach(c => c.classList.remove('selected'));
      btn.classList.add('selected');
      state.answers[`q${step}`] = opt.value;
      saveState(state);
      btnScoredNext.disabled = false;
      setTimeout(() => btnScoredNext.click(), 260);
    });

    scoredChoices.appendChild(btn);
  });
}

function renderScoredScreen(step) {
  const si = sysIdx(step);
  const qi = qIdx(step);
  const sys = SYSTEMS[si];
  const q = sys.questions[qi];

  updateProgress(step);

  if (qi === 0) {
    introHeadline.textContent = sys.intro.headline;
    introBody.textContent = sys.intro.body;
    show(systemIntro);
    setTimeout(() => {
      systemIntro.style.opacity = '0';
      systemIntro.style.transition = 'opacity 0.5s';
      setTimeout(() => { hide(systemIntro); systemIntro.style.opacity = '1'; systemIntro.style.transition = ''; }, 500);
    }, 4000);
  } else {
    hide(systemIntro);
  }

  scoredQuestion.textContent = q.text;

  if (q.type === 'slider') {
    const savedVal = state.answers[`q${step}`] ?? 5;
    diagSlider.value = savedVal;
    sliderNum.textContent = savedVal;
    scoredSliderWrap.style.display = 'block';
    scoredChoices.style.display = 'none';
    btnScoredNext.disabled = false;
  } else {
    scoredSliderWrap.style.display = 'none';
    renderScoredChoices(step, q.type);
  }

  btnScoredBack.disabled = step === 0;
  show(scoredScreen);
  hide(profileScreen);
}

function showPhase() {
  hide(landing, quiz, emailGate, calculating);

  if (state.phase === 'landing') {
    show(landing);
    return;
  }
  if (state.phase === 'profile') {
    show(quiz);
    hide(scoredScreen);
    renderProfileScreen(state.profileStep);
    return;
  }
  if (state.phase === 'scored') {
    show(quiz);
    hide(profileScreen);
    renderScoredScreen(state.scoredStep);
    return;
  }
  if (state.phase === 'gate') {
    show(emailGate);
    if (state.name) gateName.value = state.name;
    if (state.email) gateEmail.value = state.email;
    validateGate();
    return;
  }
  if (state.phase === 'calculating') {
    show(calculating);
    setTimeout(finishAndRedirect, 1800);
    return;
  }
}

function validateGate() {
  const ok = gateName.value.trim().length > 0
    && gateEmail.value.includes('@')
    && gateConsent.checked;
  btnGateNext.disabled = !ok;
}

function finishAndRedirect() {
  const s = [0,1,2,3].map(si =>
    [0,1,2,3,4].reduce((acc, qi) => acc + (state.answers[`q${si*5+qi}`] ?? 5), 0)
  );
  const total = s.reduce((a, b) => a + b, 0);
  const bn = s.indexOf(Math.min(...s)) + 1;
  const tier = total <= 50 ? 'reactive' : total <= 100 ? 'emerging' : total <= 150 ? 'leverage' : 'mastery';
  const type = state.profile.type || 'other';

  // Send complete lead data before redirecting
  const leadPayload = JSON.stringify({
    name:  state.name  || '',
    email: state.email || '',
    score: total,
    tier,
    type,
  });
  navigator.sendBeacon('https://spn.rhinoberry.com/webhook/cvv-lead-capture',
    new Blob([leadPayload], { type: 'application/json' })
  );

  sessionStorage.removeItem(STORAGE_KEY);
  window.location.href = `/score/results?score=${total}&tier=${tier}&s1=${s[0]}&s2=${s[1]}&s3=${s[2]}&s4=${s[3]}&bn=${bn}&type=${encodeURIComponent(type)}`;
}

// ── EVENT LISTENERS ──────────────────────────────────────────

document.getElementById('btn-start').addEventListener('click', () => {
  if (loadState()) {
    state = loadState();
    // Check if there's a real previous session to resume
    if (state.phase !== 'landing') {
      expiredShown = true;
      const notice = document.createElement('p');
      notice.className = 'expired-notice';
      notice.textContent = 'Resuming your previous session...';
      document.querySelector('.diag-inner').insertBefore(notice, document.querySelector('.diag-inner').firstChild);
      setTimeout(() => notice.remove(), 2000);
    }
  } else {
    state = freshState();
    state.phase = 'profile';
    state.profileStep = 0;
    saveState(state);
  }
  if (state.phase === 'landing') {
    state.phase = 'profile';
    state.profileStep = 0;
    saveState(state);
  }
  showPhase();
});

btnProfileNext.addEventListener('click', () => {
  if (state.profileStep < 2) {
    state.profileStep++;
    saveState(state);
    renderProfileScreen(state.profileStep);
  } else {
    state.phase = 'scored';
    state.scoredStep = 0;
    saveState(state);
    showPhase();
  }
});

btnProfileBack.addEventListener('click', () => {
  if (state.profileStep > 0) {
    state.profileStep--;
    saveState(state);
    renderProfileScreen(state.profileStep);
  } else {
    state.phase = 'landing';
    saveState(state);
    showPhase();
  }
});

diagSlider.addEventListener('input', () => {
  const val = parseInt(diagSlider.value);
  sliderNum.textContent = val;
  state.answers[`q${state.scoredStep}`] = val;
  saveState(state);
});

btnScoredNext.addEventListener('click', () => {
  const cq = SYSTEMS[sysIdx(state.scoredStep)].questions[qIdx(state.scoredStep)];
  if (cq.type === 'slider') {
    state.answers[`q${state.scoredStep}`] = parseInt(diagSlider.value);
    saveState(state);
  }

  if (state.scoredStep === 9) {
    state.phase = 'gate';
    saveState(state);
    showPhase();
    return;
  }
  if (state.scoredStep === 19) {
    state.phase = 'calculating';
    saveState(state);
    showPhase();
    return;
  }
  state.scoredStep++;
  saveState(state);
  renderScoredScreen(state.scoredStep);
});

btnScoredBack.addEventListener('click', () => {
  if (state.scoredStep === 0) {
    state.phase = 'profile';
    state.profileStep = 2;
    saveState(state);
    showPhase();
  } else {
    state.scoredStep--;
    saveState(state);
    renderScoredScreen(state.scoredStep);
  }
});

btnGateNext.addEventListener('click', () => {
  state.name = gateName.value.trim();
  state.email = gateEmail.value.trim();
  state.phase = 'scored';
  state.scoredStep = 10;
  saveState(state);
  showPhase();

  // Fire and forget — capture lead in Spinnerak
  fetch('https://spn.rhinoberry.com/webhook/cvv-lead-capture', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      name:  state.name,
      email: state.email,
      score: null, // not yet calculated — captured at gate
      tier:  null,
      type:  state.profile.type || 'other',
    }),
  }).catch(() => {}); // silent fail — never block the quiz
});

btnGateBack.addEventListener('click', () => {
  state.phase = 'scored';
  state.scoredStep = 9;
  saveState(state);
  showPhase();
});

gateName.addEventListener('input', validateGate);
gateEmail.addEventListener('input', validateGate);
gateConsent.addEventListener('change', validateGate);

// ── INIT ─────────────────────────────────────────────────────
showPhase();
</script>

</Scorecard>
