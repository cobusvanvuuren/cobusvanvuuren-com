---
import Scorecard from '../../layouts/Scorecard.astro';
---

<Scorecard
  title="Your Business Systems Score — Cobus van Vuuren"
  description="Your Business Systems Diagnostic results. See your score across 4 systems, find your bottleneck, and get specific actions to take today."
>

<style>
  /* ── OUTER SHELL ── */
  .results-outer {
    min-height: 100vh;
  }

  /* No-results fallback */
  #no-results {
    max-width: 640px;
    margin: 0 auto;
    padding: 5rem 1.5rem;
    text-align: center;
    display: none;
  }
  #no-results h2 {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-ivory);
    margin-bottom: 1rem;
  }
  #no-results p {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--color-smoke);
    margin-bottom: 2rem;
  }

  /* ── SCORE HERO (full-width band, matches nav) ── */
  .score-hero {
    width: 100%;
    background: rgba(255,255,255,0.025);
    border-bottom: 1px solid rgba(255,255,255,0.07);
    padding: 4.5rem 0 5.5rem;
  }
  .score-hero-inner {
    max-width: 48rem;
    margin: 0 auto;
    padding: 0 1.5rem;
    text-align: center;
  }
  .score-label {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-smoke);
    margin-bottom: 1rem;
  }
  .score-number {
    font-family: var(--font-serif);
    font-size: clamp(4rem, 10vw, 7rem);
    font-weight: 700;
    color: var(--color-crimson);
    line-height: 1;
    letter-spacing: -0.03em;
  }
  .score-denom {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    font-weight: 400;
    color: var(--color-smoke);
    margin-left: 0.2em;
  }
  .tier-badge {
    display: inline-block;
    background: var(--color-crimson);
    color: #fff;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding: 0.4rem 1rem;
    border-radius: 4px;
    margin: 1.25rem 0 1.5rem;
  }
  .tier-desc {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 400;
    color: var(--color-smoke);
    line-height: 1.7;
    max-width: 480px;
    margin: 0 auto 2rem;
  }

  /* ── TIER LADDER ── */
  .tier-ladder {
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0.75rem 0 0.25rem;
    flex-wrap: wrap;
  }
  .tier-step {
    display: flex;
    align-items: center;
  }
  .tier-step-name {
    font-family: var(--font-sans);
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(160,156,148,0.35);
    padding: 0.3rem 0.5rem;
    position: relative;
  }
  .tier-step-name.active {
    color: var(--color-ivory);
    font-weight: 700;
  }
  .tier-step-name.active::after {
    content: '';
    display: block;
    width: 100%;
    height: 2px;
    background: var(--color-crimson);
    position: absolute;
    bottom: -3px;
    left: 0;
  }
  .tier-arrow {
    color: rgba(160,156,148,0.2);
    font-size: 0.65rem;
    padding: 0 0.1rem;
  }

  /* ── COST GAP STATS ── */
  .cost-gap-stats {
    display: flex;
    justify-content: center;
    gap: 3rem;
    margin-top: 2rem;
    padding-top: 1.75rem;
    border-top: 1px solid rgba(255,255,255,0.06);
    flex-wrap: wrap;
  }
  .cost-stat {
    text-align: center;
  }
  .cost-stat-num {
    display: block;
    font-family: var(--font-serif);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    color: var(--color-copper);
    line-height: 1;
  }
  .cost-stat-label {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 400;
    letter-spacing: 0.04em;
    color: rgba(160,156,148,0.7);
    margin-top: 0.4rem;
    max-width: 140px;
    margin-left: auto;
    margin-right: auto;
  }

  /* ── ACTIONABLE INSIGHTS SECTION ── */
  .insights-section {
    margin-bottom: 5.5rem;
  }
  .insights-lead {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--color-smoke);
    line-height: 1.7;
    margin-bottom: 1.75rem;
    max-width: 520px;
  }
  .insight-card {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    padding: 1.25rem 1.25rem;
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 10px;
    margin-bottom: 0.85rem;
    background: rgba(255,255,255,0.015);
    transition: border-color 0.2s;
  }
  .insight-card:hover { border-color: rgba(255,255,255,0.1); }
  .insight-num {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: rgba(200,40,44,0.12);
    border: 1px solid rgba(200,40,44,0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--color-crimson);
    flex-shrink: 0;
    margin-top: 1px;
  }
  .insight-body { flex: 1; }
  .insight-title {
    font-family: var(--font-sans);
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--color-ivory);
    margin-bottom: 0.3rem;
    line-height: 1.4;
  }
  .insight-detail {
    font-family: var(--font-sans);
    font-size: 0.82rem;
    color: var(--color-smoke);
    line-height: 1.6;
  }

  /* ── NARRATIVE BRIDGE ── */
  .narrative-bridge {
    margin-bottom: 5rem;
    padding: 1.5rem 1.75rem;
    border: 1px solid rgba(255,255,255,0.06);
    border-left: 3px solid var(--color-copper);
    border-radius: 0 10px 10px 0;
    background: rgba(255,255,255,0.015);
  }
  .narrative-bridge p {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--color-smoke);
    line-height: 1.7;
    margin: 0;
  }
  .narrative-bridge strong {
    color: var(--color-ivory);
    font-weight: 600;
  }

  /* ── RESULTS CONTENT (narrow column) ── */
  .results-content {
    max-width: 640px;
    margin: 0 auto;
    padding: 4rem 1.5rem 7rem;
  }

  /* ── 4 SYSTEM CARDS ── */
  .systems-section {
    margin-bottom: 5.5rem;
  }
  .section-eyebrow {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-smoke);
    margin-bottom: 1.5rem;
  }
  .system-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    row-gap: 1.5rem;
    align-items: stretch;
  }
  .sys-card {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 12px;
    padding: 1.75rem;
    transition: border-color 0.2s;
  }
  .sys-card.bottleneck {
    border-color: var(--color-crimson);
    background: rgba(200,40,44,0.04);
  }
  .sys-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
  }
  .sys-name {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ivory);
  }
  .sys-card.bottleneck .sys-name {
    color: var(--color-crimson);
  }
  .bottleneck-tag {
    font-family: var(--font-sans);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-crimson);
    border: 1px solid rgba(200,40,44,0.4);
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
  }
  .sys-score-bar-wrap {
    height: 5px;
    background: rgba(255,255,255,0.06);
    border-radius: 5px;
    margin-bottom: 0.6rem;
    overflow: hidden;
  }
  .sys-score-bar {
    height: 100%;
    border-radius: 5px;
    background: var(--color-smoke);
  }
  .sys-score-bar.bar-strong    { background: #6bbf7a; }
  .sys-score-bar.bar-developing { background: #e8a838; }
  .sys-score-bar.bar-needs     { background: var(--color-crimson); }
  .sys-score-text {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.5rem;
  }
  .sys-score-fraction {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-ivory);
  }
  .sys-score-label {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .label-strong     { color: #6bbf7a; }
  .label-developing { color: #e8a838; }
  .label-needs      { color: var(--color-crimson); }
  .sys-feedback {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    color: var(--color-smoke);
    line-height: 1.55;
    margin-top: 0.35rem;
  }

  /* ── BOTTLENECK BLOCK ── */
  .bottleneck-block {
    background: rgba(200,40,44,0.05);
    border: 1px solid rgba(200,40,44,0.2);
    border-top: 3px solid var(--color-crimson);
    border-radius: 12px;
    padding: 2.25rem;
    margin-bottom: 5.5rem;
  }
  .bottleneck-block .bn-label {
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-crimson);
    margin-bottom: 0.5rem;
  }
  .bottleneck-block .bn-name {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-ivory);
    margin-bottom: 1rem;
    line-height: 1.15;
  }
  .bottleneck-block .bn-body {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--color-smoke);
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }
  .bottleneck-block .bn-pivot {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-ivory);
    padding-top: 1rem;
    border-top: 1px solid rgba(255,255,255,0.08);
    line-height: 1.5;
  }

  /* ── POPIA NOTE ── */
  .popia-results {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    color: rgba(94,90,86,0.55);
    line-height: 1.55;
    margin-bottom: 2rem;
    padding: 0.75rem 1rem;
    border: 1px solid rgba(255,255,255,0.04);
    border-radius: 6px;
  }

  /* ── CTA BLOCKS ── */
  .cta-block {
    border-radius: 16px;
    padding: 2.5rem;
    margin-bottom: 2rem;
  }
  .cta-block.reactive,
  .cta-block.emerging,
  .cta-block.mastery {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.07);
  }
  .cta-block.leverage {
    background: rgba(200,40,44,0.04);
    border: 1px solid rgba(200,40,44,0.15);
  }
  .cta-h2 {
    font-family: var(--font-serif);
    font-size: clamp(1.35rem, 3vw, 1.75rem);
    font-weight: 700;
    color: var(--color-ivory);
    line-height: 1.2;
    margin-bottom: 0.75rem;
    letter-spacing: -0.01em;
  }
  .cta-body {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--color-smoke);
    line-height: 1.65;
    margin-bottom: 1.25rem;
  }
  .seq-callout {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--color-ivory);
    font-style: italic;
    border-left: 3px solid var(--color-copper);
    padding: 0.4rem 1rem 0.4rem 1.25rem;
    margin: 0.25rem 0 1.5rem;
    line-height: 1.45;
  }

  /* Foundation tips */
  .tips-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }
  .tip-item {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
  }
  .tip-num {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: rgba(200,40,44,0.15);
    border: 1px solid rgba(200,40,44,0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--color-crimson);
    flex-shrink: 0;
    margin-top: 2px;
  }
  .tip-text {
    font-family: var(--font-sans);
    font-size: 0.88rem;
    color: var(--color-smoke);
    line-height: 1.55;
  }

  /* Kill-objection reframe */
  .reframe-block {
    background: rgba(255,255,255,0.03);
    border-radius: 10px;
    padding: 1.1rem 1.25rem;
    margin-bottom: 1.25rem;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--color-ivory);
    line-height: 1.65;
    font-style: italic;
  }

  /* Guarantee box */
  .guarantee-box {
    border-top: 2px solid var(--color-crimson);
    background: rgba(255,255,255,0.02);
    border-radius: 0 0 10px 10px;
    padding: 1.1rem 1.25rem;
    margin-bottom: 1.5rem;
  }
  .guarantee-box .guar-label {
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-crimson);
    margin-bottom: 0.35rem;
  }
  .guarantee-box .guar-text {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--color-ivory);
    line-height: 1.6;
  }

  /* Button row */
  .btn-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
    margin-top: 0.5rem;
  }
  @media (max-width: 500px) {
    .btn-row { flex-direction: column; align-items: stretch; }
    .btn-row > * { width: 100%; text-align: center !important; }
  }

  /* ── IMPROVEMENT POTENTIAL CALLOUT ── */
  .improvement-potential {
    margin-top: 1.5rem;
    padding: 0.9rem 1.25rem;
    border: 1px solid rgba(166,124,82,0.2);
    border-radius: 10px;
    background: rgba(166,124,82,0.05);
    font-family: var(--font-sans);
    font-size: 0.88rem;
    color: rgba(160,156,148,0.8);
    line-height: 1.6;
    text-align: left;
  }
  .improvement-potential strong { color: var(--color-ivory); font-weight: 600; }

  /* ── TESTIMONIALS BLOCK ── */
  .testimonials-section {
    margin-bottom: 3.5rem;
  }
  .testimonials-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 1rem;
    margin-top: 1.25rem;
  }
  .testimonial-card {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 12px;
    padding: 1.25rem 1.25rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .testimonial-stars {
    color: var(--color-copper);
    font-size: 0.75rem;
    letter-spacing: 0.05em;
  }
  .testimonial-quote {
    font-family: var(--font-sans);
    font-size: 0.82rem;
    color: rgba(160,156,148,0.85);
    line-height: 1.6;
    flex: 1;
    font-style: italic;
  }
  .testimonial-author {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--color-smoke);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  @media (max-width: 600px) {
    .testimonials-grid { grid-template-columns: 1fr; }
  }

  /* ── INLINE AUDIT SELL BLOCK ── */
  .audit-sell-block {
    background: rgba(200,40,44,0.04);
    border: 1px solid rgba(200,40,44,0.18);
    border-top: 3px solid var(--color-crimson);
    border-radius: 16px;
    padding: 2.5rem;
    margin-bottom: 2rem;
  }
  .audit-sell-eyebrow {
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-crimson);
    margin-bottom: 0.6rem;
  }
  .audit-sell-h2 {
    font-family: var(--font-serif);
    font-size: clamp(1.3rem, 3vw, 1.7rem);
    font-weight: 700;
    color: var(--color-ivory);
    line-height: 1.2;
    margin-bottom: 1.5rem;
    letter-spacing: -0.01em;
  }
  .audit-features {
    list-style: none;
    padding: 0;
    margin: 0 0 1.75rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .audit-features li {
    display: flex;
    gap: 0.7rem;
    align-items: flex-start;
    font-family: var(--font-sans);
    font-size: 0.92rem;
    color: var(--color-sand);
    line-height: 1.5;
  }
  .audit-features li::before {
    content: '✓';
    color: var(--color-crimson);
    font-weight: 700;
    flex-shrink: 0;
  }
  .audit-sell-price {
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-smoke);
    margin-bottom: 1.5rem;
    letter-spacing: -0.01em;
  }
  .audit-sell-price strong {
    color: var(--color-ivory);
    font-size: 1.35rem;
    font-weight: 700;
  }
  .audit-popia {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: rgba(94,90,86,0.6);
    line-height: 1.55;
    margin-top: 1.25rem;
  }
  .audit-more-link {
    display: block;
    margin-top: 0.75rem;
    font-family: var(--font-sans);
    font-size: 0.82rem;
    color: var(--color-smoke);
    text-decoration: none;
    transition: color 0.2s;
  }
  .audit-more-link:hover { color: var(--color-ivory); }

  /* Video embed */
  .video-slot {
    border: 1px dashed rgba(255,255,255,0.12);
    border-radius: 10px;
    padding: 2rem;
    text-align: center;
    margin-bottom: 1.5rem;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    color: rgba(94,90,86,0.5);
  }

  @media (max-width: 560px) {
    .system-cards    { grid-template-columns: 1fr; }
    .results-content { padding: 3rem 1.25rem 5rem; }
    .score-hero      { padding: 3rem 0 4rem; }
    .cost-gap-stats  { gap: 2rem; }
    .insight-card    { padding: 1rem; }
    .narrative-bridge { padding: 1.25rem 1.25rem; }
  }

  /* ── ANIMATIONS ── */
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes scaleIn {
    from { opacity: 0; transform: scale(0.95); }
    to   { opacity: 1; transform: scale(1); }
  }
  @keyframes pulseGlow {
    0%, 100% { box-shadow: 0 0 0 0 rgba(200,40,44,0); }
    50%       { box-shadow: 0 0 24px 4px rgba(200,40,44,0.35); }
  }

  .anim-fade-up {
    opacity: 0;
    animation: fadeInUp 0.55s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  .anim-scale-in {
    opacity: 0;
    animation: scaleIn 0.45s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  .sys-card:nth-child(1) { animation-delay: 0.05s; }
  .sys-card:nth-child(2) { animation-delay: 0.12s; }
  .sys-card:nth-child(3) { animation-delay: 0.19s; }
  .sys-card:nth-child(4) { animation-delay: 0.26s; }

  .cta-block .btn-primary {
    animation: pulseGlow 2.8s ease-in-out infinite;
    animation-delay: 1.5s;
  }
</style>

<div class="results-outer">

  <!-- NO RESULTS (fallback) -->
  <div id="no-results">
    <h2>No results found.</h2>
    <p>It looks like you haven't completed the diagnostic yet.</p>
    <a href="/score" class="btn-primary">Take the Diagnostic →</a>
  </div>

  <!-- RESULTS (shown by JS) -->
  <div id="results-content" style="display:none;">

    <!-- SCORE HERO — full-width band, aligns with nav -->
    <div class="score-hero anim-fade-up" style="animation-delay:0s;">
      <div class="score-hero-inner">
        <p class="score-label">Your Business Systems Score</p>
        <div>
          <span class="score-number" id="score-num">0</span><span class="score-denom">/ 200</span>
        </div>
        <div id="tier-ladder"></div>
        <div><span class="tier-badge" id="tier-badge">REACTIVE</span></div>
        <p class="tier-desc" id="tier-desc"></p>
        <div class="cost-gap-stats" id="cost-gap"></div>
        <div class="improvement-potential" id="improvement-potential" style="display:none;max-width:420px;margin:1.5rem auto 0;"></div>
      </div>
    </div>

    <!-- CONTENT SECTIONS — narrow column -->
    <div class="results-content">

      <!-- 4 SYSTEM CARDS -->
      <div class="systems-section anim-fade-up" style="animation-delay:0.15s;">
        <p class="section-eyebrow">Your 4 systems</p>
        <div class="system-cards" id="system-cards"></div>
      </div>

      <!-- BOTTLENECK BLOCK -->
      <div class="bottleneck-block anim-fade-up" id="bottleneck-block" style="animation-delay:0.3s;">
        <p class="bn-label">Your primary bottleneck</p>
        <h3 class="bn-name" id="bn-name"></h3>
        <p class="bn-body" id="bn-body"></p>
        <p class="bn-pivot">This is what a Business Automation Audit addresses first.</p>
      </div>

      <!-- POPIA NOTE (prof-services only) -->
      <p class="popia-results" id="popia-note" style="display:none;">
        Note for professional services firms: the audit operates at the workflow level, not the data level. No client files, no financial records, no POPIA exposure.
      </p>

      <!-- ACTIONABLE INSIGHTS -->
      <div class="insights-section anim-fade-up" id="insights-block" style="animation-delay:0.4s;"></div>

      <!-- NARRATIVE BRIDGE -->
      <div class="narrative-bridge anim-fade-up" id="narrative-bridge" style="animation-delay:0.5s;display:none;"></div>

      <!-- TESTIMONIALS (shown for leverage/emerging tiers) -->
      <div id="testimonials-block" style="display:none;"></div>

      <!-- TIER CTA BLOCK -->
      <div id="cta-block"></div>

    </div>
  </div>

</div>

<script>
const SYSTEM_NAMES  = ['Intelligence Capture', 'Decision Speed', 'Process Independence', 'Time Reclamation'];
const TIERS_ORDER   = ['reactive', 'emerging', 'leverage', 'mastery'];
const TIERS_LABELS  = ['Reactive', 'Emerging', 'Leverage', 'Mastery'];

const TIER_DATA = {
  reactive: {
    badge: 'REACTIVE',
    desc: 'Your business is running on your personal bandwidth — and that caps your income, your time, and your growth. This is where most SA professional services firms start. The good news: the leverage is there, waiting to be unlocked.',
  },
  emerging: {
    badge: 'EMERGING',
    desc: "You've started to build systems — but they're not wired together yet. You have islands of process and still too much running through you personally. The infrastructure is partially there. You need a clear build order.",
  },
  leverage: {
    badge: 'LEVERAGE',
    desc: "Real systems in 2–3 areas. You've reclaimed bandwidth and your team is starting to operate more independently. The gaps are specific now — and closing them is a focused build, not a full overhaul.",
  },
  mastery: {
    badge: 'MASTERY',
    desc: "AI is woven into your operating system. Your business runs on clarity. You make fewer decisions, do less low-leverage work, and your revenue isn't capped by your personal hours.",
  },
};

const BOTTLENECK_BODIES = [
  "Your business is losing context. Client history, commitments, and follow-ups are living in people's heads instead of a system. When information isn't captured automatically, it leaks — and leaked information is leaked revenue. This is the foundation every other system depends on.",
  "Your business is slower than it needs to be because decisions — especially responses to new enquiries — are waiting on you. The 42-hour average response time for SA professional services firms isn't a resource problem. It's a systems problem. And it's costing you clients.",
  "Too much of how your business works lives only in your head. Every time you explain a process, every time your team asks a question you've answered before — that's a system waiting to be documented. Until it is, you're the manual override.",
  "You're still doing work that doesn't require your expertise. Admin, compliance paperwork, client follow-ups, reporting — these aren't where your professional value sits. Reclaiming those hours is the fastest path to either more revenue or more freedom — whichever you want first.",
];

const SYS_FEEDBACK = {
  strong:     ['This system is working. Maintain it and build on it.',
               'Lead response infrastructure is strong. Keep the standard high.',
               'Your processes are documented and running. Strong foundation.',
               "You're working on the right things. Keep the standard."],
  developing: ['Context capture is patchy. Some enquiries and commitments are still falling through.',
               'Response times are inconsistent. Decisions still wait on you too often.',
               'Some processes are documented. Others still depend on you personally.',
               'You\'ve started delegating but still do too much low-leverage work yourself.'],
  needs:      ['Critical context is living in heads, not systems. This is your fastest-return fix.',
               'New enquiries wait hours — sometimes days — for a response. This is costing you clients.',
               'Almost everything runs through you. Documenting one core process this week is the starting point.',
               "Too much of your week is spent on work that shouldn't require your expertise."],
};

function getSysLabel(score) {
  if (score >= 40) return { cls: 'label-strong',    text: 'Strong',          fbIdx: 0 };
  if (score >= 25) return { cls: 'label-developing', text: 'Developing',      fbIdx: 1 };
  return               { cls: 'label-needs',      text: 'Needs attention',  fbIdx: 2 };
}

const AUDIT_SELL_HTML = `
  <div class="audit-sell-block" data-anim="scale-in">
    <p class="audit-sell-eyebrow">Claim Your Audit</p>
    <h2 class="audit-sell-h2">Here's exactly what the audit delivers</h2>
    <ul class="audit-features">
      <li>90-minute intake — walk us through your week. No prep needed.</li>
      <li>Written report delivered in 5 business days.</li>
      <li>R50,000 minimum annual savings identified — or full refund.</li>
    </ul>
    <p class="audit-sell-price"><strong>R5,497</strong> — once-off, no retainer</p>
    <div class="btn-row">
      <a href="https://paystack.com/buy/business-ai-audit" class="btn-primary" onclick="gtag&&gtag('event','audit_cta_click',{event_category:'CTA',event_label:'results-page'})">Claim Your Audit →</a>
      <a href="https://call.rhinoberry.com/meeting" class="btn-ghost-dark" target="_blank" rel="noopener">Book a 20-min call first →</a>
    </div>
    <a href="/audit" class="audit-more-link">Read more about the Business Automation Audit →</a>
    <p class="audit-popia">The audit operates at the workflow level only — we never ask for client data, financial records, or anything POPIA-sensitive.</p>
  </div>`;

function buildCTA(tier, score) {
  if (tier === 'reactive') {
    return `
      <div class="cta-block reactive">
        <h2 class="cta-h2">The foundation isn't built yet — and that's exactly where the leverage is hiding.</h2>
        <p class="cta-body">Most businesses at this stage try to bolt AI onto chaos. The move that creates the most lasting leverage is simpler: start with these three foundation steps.</p>
        <ul class="tips-list">
          <li class="tip-item"><span class="tip-num">1</span><span class="tip-text">Get your client contact list into one place before any automation. A messy list makes every system downstream worse.</span></li>
          <li class="tip-item"><span class="tip-num">2</span><span class="tip-text">Document one recurring task this week — any task you do more than twice a month. Take a voice note, have AI transcribe it. That's your first system.</span></li>
          <li class="tip-item"><span class="tip-num">3</span><span class="tip-text">Measure your response time to new enquiries for one week. Write it down. That number alone will show you your highest-leverage starting point.</span></li>
        </ul>
        <p class="cta-body">Want weekly business systems insights delivered to your inbox?</p>
        <div class="btn-row">
          <a href="https://cobusvanvuuren.com" class="btn-primary">Get Weekly Insights →</a>
        </div>
        <div style="margin-top:1.25rem;padding-top:1.25rem;border-top:1px solid rgba(255,255,255,0.06);">
          <p style="font-family:var(--font-sans);font-size:0.85rem;color:var(--color-smoke);line-height:1.6;margin-bottom:0.75rem;">Follow along on LinkedIn — I share what I'm learning building better business systems for SA owner-operators.</p>
          <a href="https://www.linkedin.com/in/cobusvanvuuren/" class="btn-ghost-dark" target="_blank" rel="noopener">Follow on LinkedIn →</a>
        </div>
      </div>`;
  }

  if (tier === 'emerging') {
    return `
      <div class="cta-block emerging">
        <h2 class="cta-h2">You've started. But your systems aren't wired together yet.</h2>
        <p class="cta-body">Most businesses at this level try to fix everything at once.</p>
        <p class="seq-callout">The gap between Emerging and Leverage isn't effort — it's sequence.</p>
        <p class="cta-body">Your bottleneck is identified above. Fixing it first means everything else compounds. Ready to map exactly what to build — in the right order?</p>
      </div>
      ${AUDIT_SELL_HTML}`;
  }

  if (tier === 'leverage') {
    return `
      <div class="cta-block leverage" style="margin-bottom:1.5rem;">
        <h2 class="cta-h2">Real systems in 2–3 areas. The gaps are specific — and fixable.</h2>
        <div class="reframe-block">"The audit doesn't cost R5,497 — it finds R50,000. The fee is what you pay to discover exactly where your business is losing money it doesn't know about. If we can't find R50,000 in annual savings opportunities specific to your business, you pay nothing. The risk is ours."</div>
      </div>
      ${AUDIT_SELL_HTML}`;
  }

  return `
    <div class="cta-block mastery">
      <h2 class="cta-h2">Your business is already in the top tier. Here's how to compound it.</h2>
      <p class="cta-body">Mastery-level businesses don't need a diagnostic — they need an implementation partner. The next leverage point is building the specific AI systems that move your highest-ROI processes from manual to automatic.</p>
      <div class="video-slot" id="video-embed">
        Video coming soon — check back after launch.
      </div>
      <div class="btn-row">
        <a href="https://call.rhinoberry.com/meeting" class="btn-primary">Book a call to discuss Implementation →</a>
        <a href="https://wa.me/27600553283" class="btn-ghost-dark" target="_blank" rel="noopener">Chat on WhatsApp first →</a>
      </div>
    </div>`;
}

function buildInsights(tier, bn) {
  const sysNames = ['Intelligence Capture', 'Decision Speed', 'Process Independence', 'Time Reclamation'];
  const bn0 = SYSTEM_NAMES[bn];

  const data = {
    reactive: {
      headline: 'Here is where to start first',
      lead: 'One focused fix creates more leverage than ten scattered improvements. Your ' + bn0 + ' system is the entry point — because fixing it first makes everything else easier to build on.',
      actions: [
        { title: 'This week: get your ' + bn0 + ' data into one place', detail: 'Before any automation can work, the raw information needs to be in a system — not split across emails, WhatsApp threads, and your memory. Even a spreadsheet beats nothing.' },
        { title: 'Time one task you repeat more than twice a month', detail: 'Set a timer. Write down how long it actually takes. That number is your baseline — and it will immediately show you your fastest-return automation opportunity.' },
        { title: 'Find the one question your team asks you most often', detail: 'That recurring question is a process waiting to be documented. Answer it in a voice note this week. An AI can transcribe it in five minutes. That is your first system.' },
      ]
    },
    emerging: {
      headline: 'You are 60% there — here is what the next 40% looks like',
      lead: 'The gap between Emerging and Leverage is not effort — it is sequence. Your ' + bn0 + ' system is still creating friction. Fix the connection points first, then the coverage.',
      actions: [
        { title: 'Identify one manual step in your ' + bn0 + ' system', detail: 'Find the step that still requires you personally — an approval, a response, a decision. That is your highest-leverage automation target right now.' },
        { title: 'Connect your two best-working systems', detail: 'You have isolated pockets of process. Pick the two that are most developed and find the handoff point between them. Automating that single handoff compounds everything downstream.' },
        { title: 'Set a 2-week deadline for one process handoff', detail: 'Pick one task your team currently asks you about. Document the decision logic and hand it off completely within 14 days. Measure whether the quality holds.' },
      ]
    },
    leverage: {
      headline: 'You are ahead of most SA businesses — here is the ceiling you are about to hit',
      lead: 'Real systems in 2-3 areas. The gaps are specific now — and closing them is a focused build, not a full overhaul. Your ' + bn0 + ' system is where the remaining drag is concentrated.',
      actions: [
        { title: 'Audit your ' + bn0 + ' system for steps still needing human sign-off', detail: 'List every approval or decision in that system that goes through you. Each one is a bottleneck. Rank them by frequency — highest-frequency goes first.' },
        { title: 'Find one metric you are not tracking that would prove the system is working', detail: 'At this level, what gets measured gets improved. If you cannot quantify whether your ' + bn0 + ' system is performing, you cannot optimise it.' },
        { title: 'Calculate the cost of the remaining gap', detail: 'Take your hourly billing rate. Multiply by the hours per month still spent on non-expertise tasks. That number is what the audit finds — and what the guarantee covers.' },
      ]
    },
    mastery: {
      headline: 'Here is how systems at this level stay optimised',
      lead: 'You are operating at a level most SA businesses never reach. The risk at Mastery is not under-automation — it is drift. Systems that are not actively maintained start to decay.',
      actions: [
        { title: 'Run a quarterly review of all active automations', detail: 'Schedule 90 minutes every quarter to audit what is running. Check for drift: processes that have changed but whose automations have not kept up. Prune anything that has become noise.' },
        { title: 'Identify one human bottleneck to systematise before year-end', detail: 'Even at Mastery, there is always one high-frequency task that still runs through a person. Find it. Systematising it is the highest-leverage move available to you right now.' },
        { title: 'Build a measurement framework for your ' + bn0 + ' system', detail: 'Define 2-3 KPIs that tell you in real time whether the system is performing. If you cannot see it, you cannot improve it — and drift is invisible until it costs you a client.' },
      ]
    }
  };

  const d = data[tier] || data.reactive;
  let html = '<p class="section-eyebrow">What to do with this</p>';
  html += '<h3 style="font-family:var(--font-serif);font-size:clamp(1.25rem,3vw,1.6rem);font-weight:700;color:var(--color-ivory);line-height:1.2;margin:0 0 1rem;letter-spacing:-0.01em">' + d.headline + '</h3>';
  html += '<p class="insights-lead">' + d.lead + '</p>';

  for (let i = 0; i < d.actions.length; i++) {
    const a = d.actions[i];
    html += '<div class="insight-card"><div class="insight-num">' + (i + 1) + '</div><div class="insight-body"><p class="insight-title">' + a.title + '</p><p class="insight-detail">' + a.detail + '</p></div></div>';
  }
  return html;
}

function buildNarrativeBridge(tier) {
  const bridges = {
    reactive: '<p>You now have more clarity on your business than most SA owners ever get from a single exercise. <strong>Here is what some of them do next:</strong> they follow along for a few weeks, implement the three steps above, and when they can see the difference a system makes — they book the audit. There is no pressure to do that today.</p>',
    emerging: '<p>You now know exactly where the drag is. <strong>Here is what most Emerging-tier business owners do next:</strong> they book a 15-minute call to talk through the sequence — which system to fix first, in what order, and how to do it without disrupting what is already working.</p>',
    leverage: '<p>You have done the hard part — you have real systems. <strong>Here is what Leverage-tier businesses typically do next:</strong> they run the audit to close the specific gaps, because at your level the ROI calculation is obvious. The audit finds the remaining friction and prices it.</p>',
    mastery:  '<p>You already know what good looks like. <strong>Here is what Mastery-tier businesses typically want next:</strong> an implementation partner who can build the specific systems that move their highest-ROI processes from manual to automatic — and who knows how to do it without breaking what is already working.</p>'
  };
  return bridges[tier] || bridges.reactive;
}

// ── RENDER ──────────────────────────────────────────────────────
function render() {
  const params = new URLSearchParams(window.location.search);
  const score  = parseInt(params.get('score') ?? '0');
  const tier   = params.get('tier') ?? '';
  const s      = [1,2,3,4].map(i => parseInt(params.get(`s${i}`) ?? '0'));
  const bn     = parseInt(params.get('bn') ?? '1') - 1; // URL param is 1-indexed
  const type   = params.get('type') ?? 'other';

  if (!params.has('score') || !tier) {
    document.getElementById('no-results').style.display = 'block';
    return;
  }

  document.getElementById('results-content').style.display = 'block';

  // Score counter animation
  const scoreEl   = document.getElementById('score-num');
  const duration  = 1100;
  const startTime = performance.now();
  function countUp(ts) {
    const progress = Math.min((ts - startTime) / duration, 1);
    const eased    = 1 - Math.pow(1 - progress, 3);
    scoreEl.textContent = Math.round(eased * score);
    if (progress < 1) requestAnimationFrame(countUp);
  }
  requestAnimationFrame(countUp);

  // Tier badge + description
  const td = TIER_DATA[tier] || TIER_DATA.reactive;
  document.getElementById('tier-badge').textContent = td.badge;
  document.getElementById('tier-desc').textContent  = td.desc;

  // Tier ladder
  const ladderEl    = document.getElementById('tier-ladder');
  ladderEl.className = 'tier-ladder';
  ladderEl.innerHTML = TIERS_ORDER.map((t, i) => {
    const isActive = t === tier;
    const arrow    = i < TIERS_ORDER.length - 1 ? '<span class="tier-arrow">›</span>' : '';
    return `<div class="tier-step"><span class="tier-step-name${isActive ? ' active' : ''}">${TIERS_LABELS[i]}</span>${arrow}</div>`;
  }).join('');

  // Cost of gap — two hero stat blocks
  const hoursWasted = ((200 - score) / 10).toFixed(1);
  const monthlyLoss = Math.round((200 - score) / 10 * 1500 * 4);
  document.getElementById('cost-gap').innerHTML = `
    <div class="cost-stat">
      <span class="cost-stat-num">${hoursWasted} hrs</span>
      <span class="cost-stat-label">per week left on the table</span>
    </div>
    <div class="cost-stat">
      <span class="cost-stat-num">R${monthlyLoss.toLocaleString()}</span>
      <span class="cost-stat-label">per month in unrealised billing</span>
    </div>
  `;

  // Improvement potential — what could be saved if weakest system reaches 25/50 (mid-leverage)
  const weakestScore = Math.min(...s);
  if (weakestScore < 25) {
    const potentialGain = 25 - weakestScore;
    const hoursGained = (potentialGain / 5).toFixed(1);
    const annualValue = Math.round(potentialGain / 5 * 4 * 1500 * 12);
    const potEl = document.getElementById('improvement-potential');
    if (potEl) {
      potEl.innerHTML = `If you improve your weakest system to <strong>Leverage</strong> level, you recover an estimated <strong>${hoursGained} hrs/week</strong> — worth <strong>R${annualValue.toLocaleString()}/year</strong> at an R1,500/hr billing rate.`;
      potEl.style.display = 'block';
    }
  }

  // System cards
  const cardsEl = document.getElementById('system-cards');
  s.forEach((syScore, i) => {
    const isBn   = i === bn;
    const lbl    = getSysLabel(syScore);
    const fb     = SYS_FEEDBACK[lbl.fbIdx === 0 ? 'strong' : lbl.fbIdx === 1 ? 'developing' : 'needs'][i];
    const pct    = (syScore / 50) * 100;
    const barCls = lbl.fbIdx === 0 ? 'bar-strong' : lbl.fbIdx === 1 ? 'bar-developing' : 'bar-needs';

    const card = document.createElement('div');
    card.className = `sys-card anim-scale-in${isBn ? ' bottleneck' : ''}`;
    card.innerHTML = `
      <div class="sys-card-header">
        <span class="sys-name">${SYSTEM_NAMES[i]}</span>
        ${isBn ? '<span class="bottleneck-tag">Bottleneck</span>' : ''}
      </div>
      <div class="sys-score-bar-wrap">
        <div class="sys-score-bar ${barCls}" style="width:0%" data-pct="${pct}"></div>
      </div>
      <div class="sys-score-text">
        <span class="sys-score-fraction">${syScore} <span style="font-size:0.75em;color:var(--color-smoke)">/ 50</span></span>
        <span class="sys-score-label ${lbl.cls}">${lbl.text}</span>
      </div>
      <p class="sys-feedback">${fb}</p>
    `;
    cardsEl.appendChild(card);
  });

  // Animate progress bars in with stagger
  setTimeout(() => {
    cardsEl.querySelectorAll('.sys-score-bar').forEach((bar, i) => {
      setTimeout(() => {
        bar.style.transition = 'width 0.9s cubic-bezier(0.34, 1.56, 0.64, 1)';
        bar.style.width = bar.dataset.pct + '%';
      }, i * 110);
    });
  }, 400);

  // Bottleneck block
  document.getElementById('bn-name').textContent = SYSTEM_NAMES[bn];
  document.getElementById('bn-body').textContent = BOTTLENECK_BODIES[bn];

  // POPIA note
  if (type === 'prof-services') {
    document.getElementById('popia-note').style.display = 'block';
  }

  // Actionable insights
  document.getElementById('insights-block').innerHTML = buildInsights(tier, bn);

  // Narrative bridge
  const bridgeEl = document.getElementById('narrative-bridge');
  bridgeEl.innerHTML = buildNarrativeBridge(tier);
  bridgeEl.style.display = 'block';

  // Testimonials — shown for leverage and emerging tiers (highest purchase intent)
  if (tier === 'leverage' || tier === 'emerging') {
    const testimonialsEl = document.getElementById('testimonials-block');
    if (testimonialsEl) {
      testimonialsEl.style.display = 'block';
      testimonialsEl.innerHTML = `
        <div class="testimonials-section" data-anim="fade-up">
          <p class="section-eyebrow">What SA business owners say about working with Cobus</p>
          <div class="testimonials-grid">
            <div class="testimonial-card">
              <span class="testimonial-stars">★★★★★</span>
              <p class="testimonial-quote">"In as little as a week, business has started to improve. Will definitely be hearing from Cobus again."</p>
              <p class="testimonial-author">Luke Hoar — Business owner</p>
            </div>
            <div class="testimonial-card">
              <span class="testimonial-stars">★★★★★</span>
              <p class="testimonial-quote">"Invaluable insight, experience and willingness to assist — he provided much needed clarity to help us grow."</p>
              <p class="testimonial-author">Yugo Roofing — Johannesburg</p>
            </div>
            <div class="testimonial-card">
              <span class="testimonial-stars">★★★★★</span>
              <p class="testimonial-quote">"Before making contact with Cobus I had no clear plan. He helped us achieve results that surpassed what we thought possible."</p>
              <p class="testimonial-author">Arnold de Wet — Swift Solar Pool Repairs</p>
            </div>
          </div>
        </div>`;
    }
  }

  // Tier CTA
  document.getElementById('cta-block').innerHTML = buildCTA(tier, score);
}

render();

// GA4 generate_lead event
(function () {
  const p = new URLSearchParams(window.location.search);
  if (!p.has('score') || !p.get('tier')) return;
  if (typeof window.dataLayer !== 'undefined') {
    window.dataLayer.push({
      event: 'generate_lead',
      score: parseInt(p.get('score') || '0'),
      tier: p.get('tier'),
    });
  }
})();
</script>

</Scorecard>
