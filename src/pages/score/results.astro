---
import Scorecard from '../../layouts/Scorecard.astro';
---

<Scorecard
  title="Your AI Readiness Results — Cobus van Vuuren"
  description="Your AI Readiness Diagnostic results. See your score across 4 systems, identify your bottleneck, and learn which system to build first."
>

<style>
  .results {
    min-height: 100vh;
    padding: 3rem 1.5rem 6rem;
  }
  .results-inner {
    max-width: 720px;
    margin: 0 auto;
  }

  /* No-results fallback */
  #no-results {
    text-align: center;
    padding: 5rem 0;
    display: none;
  }
  #no-results h2 {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-ivory);
    margin-bottom: 1rem;
  }
  #no-results p {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--color-smoke);
    margin-bottom: 2rem;
  }

  /* ── SCORE REVEAL ── */
  .score-reveal {
    text-align: center;
    padding: 2.5rem 0 3rem;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    margin-bottom: 3rem;
  }
  .score-label {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-smoke);
    margin-bottom: 1rem;
  }
  .score-number {
    font-family: var(--font-serif);
    font-size: clamp(4rem, 10vw, 7rem);
    font-weight: 700;
    color: var(--color-crimson);
    line-height: 1;
    letter-spacing: -0.03em;
  }
  .score-denom {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    font-weight: 400;
    color: var(--color-smoke);
    margin-left: 0.2em;
  }
  .tier-badge {
    display: inline-block;
    background: var(--color-crimson);
    color: #fff;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding: 0.4rem 1rem;
    border-radius: 4px;
    margin: 1rem 0 1.25rem;
  }
  .tier-desc {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 400;
    color: var(--color-smoke);
    line-height: 1.7;
    max-width: 520px;
    margin: 0 auto 1rem;
  }
  .cost-gap {
    font-family: var(--font-sans);
    font-size: 0.82rem;
    color: rgba(200,40,44,0.75);
    font-weight: 400;
    line-height: 1.6;
    max-width: 480px;
    margin: 0 auto;
    padding: 0.75rem 1rem;
    border: 1px solid rgba(200,40,44,0.15);
    border-radius: 8px;
    background: rgba(200,40,44,0.04);
  }

  /* ── 4 SYSTEM CARDS ── */
  .systems-section {
    margin-bottom: 3rem;
  }
  .section-eyebrow {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-smoke);
    margin-bottom: 1.5rem;
  }
  .system-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .sys-card {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 12px;
    padding: 1.25rem;
    transition: border-color 0.2s;
  }
  .sys-card.bottleneck {
    border-color: var(--color-crimson);
    background: rgba(200,40,44,0.04);
  }
  .sys-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
  }
  .sys-name {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ivory);
  }
  .sys-card.bottleneck .sys-name {
    color: var(--color-crimson);
  }
  .bottleneck-tag {
    font-family: var(--font-sans);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-crimson);
    border: 1px solid rgba(200,40,44,0.4);
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
  }
  .sys-score-bar-wrap {
    height: 3px;
    background: rgba(255,255,255,0.06);
    border-radius: 3px;
    margin-bottom: 0.6rem;
    overflow: hidden;
  }
  .sys-score-bar {
    height: 100%;
    border-radius: 3px;
    background: var(--color-smoke);
    transition: width 0.8s ease;
  }
  .sys-card.bottleneck .sys-score-bar {
    background: var(--color-crimson);
  }
  .sys-score-text {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.5rem;
  }
  .sys-score-fraction {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-ivory);
  }
  .sys-score-label {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .label-strong { color: #6bbf7a; }
  .label-developing { color: #e8a838; }
  .label-needs { color: var(--color-crimson); }
  .sys-feedback {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    color: var(--color-smoke);
    line-height: 1.55;
    margin-top: 0.35rem;
  }

  /* ── BOTTLENECK BLOCK ── */
  .bottleneck-block {
    background: rgba(200,40,44,0.05);
    border: 1px solid rgba(200,40,44,0.2);
    border-left: 3px solid var(--color-crimson);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 3rem;
  }
  .bottleneck-block .bn-label {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-crimson);
    margin-bottom: 0.3rem;
  }
  .bottleneck-block .bn-name {
    font-family: var(--font-serif);
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-ivory);
    margin-bottom: 0.75rem;
    line-height: 1.2;
  }
  .bottleneck-block .bn-body {
    font-family: var(--font-sans);
    font-size: 0.88rem;
    color: var(--color-smoke);
    line-height: 1.65;
    margin-bottom: 0.75rem;
  }
  .bottleneck-block .bn-pitch {
    font-family: var(--font-sans);
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--color-ivory);
    font-style: italic;
  }

  /* ── POPIA NOTE ── */
  .popia-results {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    color: rgba(94,90,86,0.55);
    line-height: 1.55;
    margin-bottom: 2rem;
    padding: 0.75rem 1rem;
    border: 1px solid rgba(255,255,255,0.04);
    border-radius: 6px;
  }

  /* ── CTA BLOCKS ── */
  .cta-block {
    border-radius: 16px;
    padding: 2rem;
    margin-bottom: 2rem;
  }
  .cta-block.reactive {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.07);
  }
  .cta-block.emerging {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.07);
  }
  .cta-block.leverage {
    background: rgba(200,40,44,0.04);
    border: 1px solid rgba(200,40,44,0.15);
  }
  .cta-block.mastery {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.07);
  }
  .cta-h2 {
    font-family: var(--font-serif);
    font-size: clamp(1.35rem, 3vw, 1.75rem);
    font-weight: 700;
    color: var(--color-ivory);
    line-height: 1.2;
    margin-bottom: 0.75rem;
    letter-spacing: -0.01em;
  }
  .cta-body {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--color-smoke);
    line-height: 1.65;
    margin-bottom: 1.25rem;
  }

  /* Foundation tips */
  .tips-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }
  .tip-item {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
  }
  .tip-num {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: rgba(200,40,44,0.15);
    border: 1px solid rgba(200,40,44,0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--color-crimson);
    flex-shrink: 0;
    margin-top: 2px;
  }
  .tip-text {
    font-family: var(--font-sans);
    font-size: 0.88rem;
    color: var(--color-smoke);
    line-height: 1.55;
  }

  /* Kill-objection reframe */
  .reframe-block {
    background: rgba(255,255,255,0.03);
    border-radius: 10px;
    padding: 1.1rem 1.25rem;
    margin-bottom: 1.25rem;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--color-ivory);
    line-height: 1.65;
    font-style: italic;
  }

  /* Guarantee box */
  .guarantee-box {
    border-top: 2px solid var(--color-crimson);
    background: rgba(255,255,255,0.02);
    border-radius: 0 0 10px 10px;
    padding: 1.1rem 1.25rem;
    margin-bottom: 1.5rem;
  }
  .guarantee-box .guar-label {
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-crimson);
    margin-bottom: 0.35rem;
  }
  .guarantee-box .guar-text {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--color-ivory);
    line-height: 1.6;
  }

  /* Button row */
  .btn-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
    margin-top: 0.5rem;
  }

  /* Video embed */
  .video-slot {
    border: 1px dashed rgba(255,255,255,0.12);
    border-radius: 10px;
    padding: 2rem;
    text-align: center;
    margin-bottom: 1.5rem;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    color: rgba(94,90,86,0.5);
  }

  /* Share section */
  .share-section {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255,255,255,0.06);
    text-align: center;
  }
  .share-label {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-smoke);
    margin-bottom: 1rem;
  }
  .share-btns {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.1rem;
    border-radius: 8px;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 500;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .share-btn:hover { opacity: 0.8; }
  .share-wa { background: #25D366; color: #fff; }
  .share-li { background: #0A66C2; color: #fff; }

  @media (max-width: 560px) {
    .system-cards { grid-template-columns: 1fr; }
    .results { padding: 2rem 1.25rem 5rem; }
  }

  /* ── ANIMATIONS ── */
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes scaleIn {
    from { opacity: 0; transform: scale(0.95); }
    to   { opacity: 1; transform: scale(1); }
  }
  @keyframes pulseGlow {
    0%, 100% { box-shadow: 0 0 0 0 rgba(200,40,44,0); }
    50%       { box-shadow: 0 0 24px 4px rgba(200,40,44,0.35); }
  }
  @keyframes barReveal {
    from { width: 0% !important; }
  }

  .anim-fade-up {
    opacity: 0;
    animation: fadeInUp 0.55s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  .anim-scale-in {
    opacity: 0;
    animation: scaleIn 0.45s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  /* Stagger delays for system cards */
  .sys-card:nth-child(1) { animation-delay: 0.05s; }
  .sys-card:nth-child(2) { animation-delay: 0.12s; }
  .sys-card:nth-child(3) { animation-delay: 0.19s; }
  .sys-card:nth-child(4) { animation-delay: 0.26s; }

  /* CTA primary button pulse */
  .cta-block .btn-primary {
    animation: pulseGlow 2.8s ease-in-out infinite;
    animation-delay: 1.5s;
  }

  /* Spacing improvements */
  .score-reveal { padding: 3rem 0 3.5rem; }
  .systems-section { margin-bottom: 3.5rem; }
  .bottleneck-block { margin-bottom: 3.5rem; padding: 2rem; }
  #cta-block { margin-bottom: 1rem; }
  .cta-block { padding: 2.5rem; }
</style>

<div class="results">
  <div class="results-inner">

    <!-- NO RESULTS (fallback) -->
    <div id="no-results">
      <h2>No results found.</h2>
      <p>It looks like you haven't completed the diagnostic yet.</p>
      <a href="/score" class="btn-primary">Take the Diagnostic →</a>
    </div>

    <!-- RESULTS (shown by JS) -->
    <div id="results-content" style="display:none;">

      <!-- SCORE REVEAL -->
      <div class="score-reveal anim-fade-up" style="animation-delay:0s;">
        <p class="score-label">Your AI Readiness Score</p>
        <div>
          <span class="score-number" id="score-num">0</span><span class="score-denom">/ 200</span>
        </div>
        <div><span class="tier-badge" id="tier-badge">REACTIVE</span></div>
        <p class="tier-desc" id="tier-desc"></p>
        <p class="cost-gap" id="cost-gap"></p>
      </div>

      <!-- 4 SYSTEM CARDS -->
      <div class="systems-section">
        <p class="section-eyebrow">Your 4 systems</p>
        <div class="system-cards" id="system-cards"></div>
      </div>

      <!-- BOTTLENECK BLOCK -->
      <div class="bottleneck-block anim-fade-up" id="bottleneck-block" style="animation-delay:0.35s;">
        <p class="bn-label">Your bottleneck</p>
        <h3 class="bn-name" id="bn-name"></h3>
        <p class="bn-body" id="bn-body"></p>
        <p class="bn-pitch">This is what a Business Automation Audit addresses first.</p>
      </div>

      <!-- POPIA NOTE (prof-services only) -->
      <p class="popia-results" id="popia-note" style="display:none;">
        Note for professional services firms: the audit operates at the workflow level, not the data level. No client files, no financial records, no POPIA exposure.
      </p>

      <!-- TIER CTA BLOCK -->
      <div id="cta-block"></div>

      <!-- SHARE -->
      <div class="share-section">
        <p class="share-label">Share your results</p>
        <div class="share-btns" id="share-btns"></div>
      </div>

    </div>

  </div>
</div>

<script>
const SYSTEM_NAMES = ['Intelligence Capture', 'Decision Speed', 'Process Independence', 'Time Reclamation'];

const TIER_DATA = {
  reactive: {
    badge: 'REACTIVE',
    desc: 'Your practice is running on your personal bandwidth — and that caps your income, your time, and your growth. This is where most SA professional services firms start. The good news: the leverage is there, waiting to be unlocked.',
  },
  emerging: {
    badge: 'EMERGING',
    desc: "You've started to build systems — but they're not wired together yet. You have islands of process and still too much running through you personally. The infrastructure is partially there. You need a clear build order.",
  },
  leverage: {
    badge: 'LEVERAGE',
    desc: 'Real systems in 2–3 areas. You\'ve reclaimed bandwidth and your team is starting to operate more independently. The gaps are specific now — and closing them is a focused build, not a full overhaul.',
  },
  mastery: {
    badge: 'MASTERY',
    desc: "AI is woven into your operating system. Your practice runs on clarity. You make fewer decisions, do less low-leverage work, and your revenue isn't capped by your personal hours.",
  },
};

const BOTTLENECK_BODIES = [
  'Your practice is losing context. Client history, commitments, and follow-ups are living in people\'s heads instead of a system. When information isn\'t captured automatically, it leaks — and leaked information is leaked revenue. This is the foundation every other system depends on.',
  'Your practice is slower than it needs to be because decisions — especially responses to new enquiries — are waiting on you. The 42-hour average response time for SA professional services firms isn\'t a resource problem. It\'s a systems problem. And it\'s costing you clients.',
  'Too much of how your practice works lives only in your head. Every time you explain a process, every time your team asks a question you\'ve answered before — that\'s a system waiting to be documented. Until it is, you\'re the manual override.',
  "You're still doing work that doesn't require your expertise. Admin, compliance paperwork, client follow-ups, reporting — these aren't where your professional value sits. Reclaiming those hours is the fastest path to either more revenue or more freedom — whichever you want first.",
];

const SYS_FEEDBACK = {
  strong:     ['This system is working. Maintain it and build on it.',
               'Lead response infrastructure is strong. Keep the standard high.',
               'Your processes are documented and running. Strong foundation.',
               'You\'re working on the right things. Keep the standard.'],
  developing: ['Context capture is patchy. Some enquiries and commitments are still falling through.',
               'Response times are inconsistent. Decisions still wait on you too often.',
               'Some processes are documented. Others still depend on you personally.',
               'You\'ve started delegating but still do too much low-leverage work yourself.'],
  needs:      ['Critical context is living in heads, not systems. This is your fastest-return fix.',
               'New enquiries wait hours — sometimes days — for a response. This is costing you clients.',
               'Almost everything runs through you. Documenting one core process this week is the starting point.',
               'Too much of your week is spent on work that shouldn\'t require your expertise.'],
};

function getSysLabel(score, sysIdx) {
  if (score >= 40) return { cls: 'label-strong', text: 'Strong', fbIdx: 0 };
  if (score >= 25) return { cls: 'label-developing', text: 'Developing', fbIdx: 1 };
  return { cls: 'label-needs', text: 'Needs attention', fbIdx: 2 };
}

function buildCTA(tier, score) {
  const paystack = 'https://pay.cobusvanvuuren.com/audit'; // placeholder — Cobus to update

  if (tier === 'reactive') {
    return `
      <div class="cta-block reactive">
        <h2 class="cta-h2">The foundation isn't built yet — and that's exactly where the leverage is hiding.</h2>
        <p class="cta-body">Most practices at this stage try to bolt AI onto chaos. The move that creates the most lasting leverage is simpler: start with these three foundation steps.</p>
        <ul class="tips-list">
          <li class="tip-item"><span class="tip-num">1</span><span class="tip-text">Get your client contact list into one place before any automation. A messy list makes every system downstream worse.</span></li>
          <li class="tip-item"><span class="tip-num">2</span><span class="tip-text">Document one recurring task this week — any task you do more than twice a month. Take a voice note, have AI transcribe it. That's your first system.</span></li>
          <li class="tip-item"><span class="tip-num">3</span><span class="tip-text">Measure your response time to new enquiries for one week. Write it down. That number alone will show you your highest-leverage starting point.</span></li>
        </ul>
        <p class="cta-body">Want weekly AI-for-practice insights delivered to your inbox?</p>
        <div class="btn-row">
          <a href="https://cobusvanvuuren.com" class="btn-primary">Get Weekly Insights →</a>
        </div>
      </div>`;
  }

  if (tier === 'emerging') {
    return `
      <div class="cta-block emerging">
        <h2 class="cta-h2">You've started. But your systems aren't wired together yet.</h2>
        <p class="cta-body">The gap between Emerging and Leverage isn't effort — it's sequence. Most practices at this level try to fix everything at once. The bottleneck identified above is where to start. Fixing it first means everything else compounds.</p>
        <p class="cta-body">Want someone to map out exactly what to build for your specific practice — in the right order?</p>
        <div class="btn-row">
          <a href="https://call.rhinoberry.com/meeting" class="btn-primary">Book a free 15-min call →</a>
        </div>
      </div>`;
  }

  if (tier === 'leverage') {
    return `
      <div class="cta-block leverage">
        <h2 class="cta-h2">Real systems in 2–3 areas. The gaps are specific — and fixable.</h2>
        <div class="reframe-block">"The audit doesn't cost R9,500 — it finds R50,000. The fee is what you pay to discover where your practice is losing money it doesn't know about. If we can't find R50,000 in annual savings opportunities specific to your practice, you pay nothing. The risk is ours."</div>
        <div class="guarantee-box">
          <p class="guar-label">Guaranteed Results</p>
          <p class="guar-text">If the audit doesn't identify at least R50,000 in annual savings opportunities specific to your practice, you receive a full refund. No questions asked.</p>
        </div>
        <div class="btn-row">
          <a href="${paystack}" class="btn-primary">Claim Your Business Automation Audit — R9,500 →</a>
          <a href="https://call.rhinoberry.com/meeting" class="btn-ghost-dark">Not sure yet? Book a free 15-min call first</a>
        </div>
        <p style="margin-top:0.75rem;font-family:var(--font-sans);font-size:0.8rem;color:var(--color-smoke);">
          Want to understand what's in the audit first?
          <a href="/audit" style="color:var(--color-ivory);text-decoration:underline;text-underline-offset:3px;">Read more about the Business Automation Audit →</a>
        </p>
      </div>`;
  }

  // mastery
  return `
    <div class="cta-block mastery">
      <h2 class="cta-h2">Your practice is already in the top tier. Here's how to compound it.</h2>
      <p class="cta-body">Mastery-level practices don't need a diagnostic — they need an implementation partner. The next leverage point is building the specific AI systems that move your highest-ROI processes from manual to automatic.</p>
      <!-- VIDEO EMBED SLOT: Cobus — paste video URL or embed code below -->
      <div class="video-slot" id="video-embed">
        Video coming soon — check back after launch.
      </div>
      <div class="btn-row">
        <a href="https://call.rhinoberry.com/meeting" class="btn-primary">Book a call to discuss Implementation →</a>
      </div>
    </div>`;
}

function buildShareBtns(score, tier) {
