// ── RENDER ────────────────────────────────────────────────────
function render() {
  const params = new URLSearchParams(window.location.search);
  const score  = parseInt(params.get('score') ?? '0');
  const tier   = params.get('tier') ?? '';
  const s      = [1,2,3,4].map(i => parseInt(params.get(`s${i}`) ?? '0'));
  const bn     = parseInt(params.get('bn') ?? '1') - 1; // 0-indexed
  const type   = params.get('type') ?? 'other';

  if (!params.has('score') || !tier) {
    document.getElementById('no-results').style.display = 'block';
    return;
  }

  document.getElementById('results-content').style.display = 'block';

  // Score counter animation
  const scoreEl = document.getElementById('score-num');
  const duration = 1100;
  const startTime = performance.now();
  function countUp(ts) {
    const progress = Math.min((ts - startTime) / duration, 1);
    const eased = 1 - Math.pow(1 - progress, 3);
    scoreEl.textContent = Math.round(eased * score);
    if (progress < 1) requestAnimationFrame(countUp);
  }
  requestAnimationFrame(countUp);

  // Tier badge + desc with entrance
  const td = TIER_DATA[tier] || TIER_DATA.reactive;
  document.getElementById('tier-badge').textContent = td.badge;
  document.getElementById('tier-desc').textContent  = td.desc;

  // Cost of gap
  const hoursWasted  = ((200 - score) / 10).toFixed(1);
  const monthlyLoss  = Math.round((200 - score) / 10 * 1500 * 4);
  document.getElementById('cost-gap').textContent =
    `At your level, the average SA professional services practice leaves ${hoursWasted} hours per week on the table. At a conservative R1,500/hour billing rate, that's R${monthlyLoss.toLocaleString()} per month.`;

  // System cards
  const cardsEl = document.getElementById('system-cards');
  s.forEach((syScore, i) => {
    const isBn  = i === bn;
    const lbl   = getSysLabel(syScore, i);
    const fb    = SYS_FEEDBACK[lbl.fbIdx === 0 ? 'strong' : lbl.fbIdx === 1 ? 'developing' : 'needs'][i];
    const pct   = (syScore / 50) * 100;

    const card = document.createElement('div');
    card.className = `sys-card anim-scale-in${isBn ? ' bottleneck' : ''}`;
    card.innerHTML = `
      <div class="sys-card-header">
        <span class="sys-name">${SYSTEM_NAMES[i]}</span>
        ${isBn ? '<span class="bottleneck-tag">Bottleneck</span>' : ''}
      </div>
      <div class="sys-score-bar-wrap">
        <div class="sys-score-bar" style="width:0%" data-pct="${pct}"></div>
      </div>
      <div class="sys-score-text">
        <span class="sys-score-fraction">${syScore} <span style="font-size:0.75em;color:var(--color-smoke)">/ 50</span></span>
        <span class="sys-score-label ${lbl.cls}">${lbl.text}</span>
      </div>
      <p class="sys-feedback">${fb}</p>
    `;
    cardsEl.appendChild(card);
  });

  // Animate bars in with stagger
  setTimeout(() => {
    cardsEl.querySelectorAll('.sys-score-bar').forEach((bar, i) => {
      setTimeout(() => {
        bar.style.transition = 'width 0.9s cubic-bezier(0.34, 1.56, 0.64, 1)';
        bar.style.width = bar.dataset.pct + '%';
      }, i * 110);
    });
  }, 400);

  // Bottleneck block
  document.getElementById('bn-name').textContent  = SYSTEM_NAMES[bn];
  document.getElementById('bn-body').textContent  = BOTTLENECK_BODIES[bn];

  // POPIA note
  if (type === 'prof-services') {
    document.getElementById('popia-note').style.display = 'block';
  }

  // Tier CTA
  document.getElementById('cta-block').innerHTML = buildCTA(tier, score);

  // Share buttons
  document.getElementById('share-btns').innerHTML = buildShareBtns(score, tier);
}

render();
</script>

</Scorecard>
